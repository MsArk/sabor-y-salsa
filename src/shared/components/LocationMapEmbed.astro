---
const embedSrc =
  "https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3038.9638475405955!2d-3.6521493234823175!3d40.38749385741742!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0xd4225c458c8bea7%3A0x40ff488939d51be3!2sC.%20Guada%C3%ADra%2C%2014%2C%20Puente%20de%20Vallecas%2C%2028018%20Madrid!5e0!3m2!1ses!2ses!4v1777733416695!5m2!1ses!2ses";

/** Sandbox: mapa necesita scripts y mismo origen; sin allow-top-navigation libre para mitigar navegación no deseada del documento padre. */
const sandboxFlags =
  "allow-scripts allow-same-origin allow-popups allow-popups-to-escape-sandbox allow-forms allow-top-navigation-by-user-activation";
---

<div class="w-full overflow-hidden rounded-xl border border-outline-variant/20 shadow-lg">
  <iframe
    title="Ubicación — Sabor &amp; Salsa, C. Guadaíra 14, Madrid"
    class="block h-[280px] w-full sm:h-[380px] md:h-[450px]"
    src={embedSrc}
    style="border:0;"
    loading="lazy"
    referrerpolicy="no-referrer"
    allow="fullscreen"
    sandbox={sandboxFlags}
    credentialless
  />
</div>
