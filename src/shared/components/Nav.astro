---
interface Props {
  activeLink?: string;
}
const { activeLink = "" } = Astro.props;

const links = [
  { label: "Manifiesto", href: "/#manifiesto" },
  { label: "Carta", href: "/#carta" },
  { label: "Barra Premium", href: "/#barra" },
  { label: "Historia", href: "/#historia" },
  { label: "Reservas", href: "/#reservas" },
];
---

<nav class="fixed top-0 w-full z-50 glass-nav">
  <div class="flex justify-between items-center max-w-7xl mx-auto px-5 md:px-8 py-4 md:py-6">
    <a class="header-logo" href="/" aria-label="Sabor y Salsa inicio">
      <img alt="Sabor &amp; Salsa Logo" class="h-10 md:h-12 w-auto object-contain" src="/logo.jpeg" />
    </a>
    <div class="hidden md:flex items-center gap-10">
      {links.map((link) => (
        <a
          class={`font-label uppercase tracking-wider text-xs font-bold spark-underline ${activeLink === link.label ? "text-primary border-primary pb-1 nav-item-active" : "text-on-surface/80 nav-link-hover"}`}
          href={link.href}
        >
          {link.label}
        </a>
      ))}
    </div>
    <div class="flex items-center gap-3">
      <a
        class="hidden md:inline-flex metallic-gradient text-on-primary font-label font-bold px-6 py-2.5 rounded-lg text-xs uppercase tracking-widest btn-hover-strong shadow-[0_0_20px_rgba(242,202,80,0.2)]"
        href="/#reservas"
      >
        Reservar mesa
      </a>
      <button
        aria-controls="mobile-menu"
        aria-expanded="false"
        class="md:hidden w-11 h-11 rounded-lg border border-primary/20 text-primary flex items-center justify-center"
        id="mobile-menu-toggle"
        type="button"
      >
        <span class="material-symbols-outlined">menu</span>
      </button>
    </div>
  </div>
  <div class="md:hidden hidden fixed inset-0 top-[72px] h-[calc(100vh-72px)] z-40 bg-surface" id="mobile-menu">
    <div class="flex flex-col items-center justify-center h-full w-full p-4 space-y-6">
      {links.map((link) => (
        <a
          class={`block py-3 text-sm uppercase tracking-[0.2em] text-center ${activeLink === link.label ? "text-primary spark-underline nav-item-active" : "text-on-surface/80 nav-link-hover"}`}
          href={link.href}
        >
          {link.label}
        </a>
      ))}
    </div>
  </div>
</nav>

<script>
  const mobileToggle = document.getElementById('mobile-menu-toggle');
  const mobileMenu = document.getElementById('mobile-menu');

  if (mobileToggle && mobileMenu) {
    mobileToggle.addEventListener('click', () => {
      const expanded = mobileToggle.getAttribute('aria-expanded') === 'true';
      mobileToggle.setAttribute('aria-expanded', String(!expanded));
      mobileMenu.classList.toggle('hidden');
    });

    mobileMenu.querySelectorAll('a').forEach((link) => {
      link.addEventListener('click', () => {
        mobileMenu.classList.add('hidden');
        mobileToggle.setAttribute('aria-expanded', 'false');
      });
    });
  }
</script>
