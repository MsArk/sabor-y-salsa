---
interface Props {
  activeLink?: string;
}
const { activeLink = "" } = Astro.props;

const links = [
  { label: "Manifiesto", href: "/#manifiesto" },
  { label: "Carta", href: "/#carta" },
  { label: "Barra", href: "/#barra" },
  { label: "Reservas", href: "/#reservas" },
];
---

<nav class="fixed top-0 left-0 right-0 z-50 flex w-full flex-col">
  <div
    id="site-nav-stack"
    class="flex w-full flex-col border-b border-primary/10 bg-[rgba(19,19,19,0.94)] backdrop-blur-md"
  >
    <!-- Sub-header: teléfonos + reserva -->
    <div class="max-w-7xl mx-auto w-full px-5 md:px-8 py-2 md:py-2.5">
      <div class="flex flex-wrap items-center justify-between gap-x-4 gap-y-2">
        <div class="flex flex-wrap items-center gap-x-4 gap-y-1 md:gap-x-6">
          <a
            class="font-label text-[11px] font-semibold uppercase tracking-[0.12em] text-on-surface/85 transition-colors hover:text-primary md:text-xs"
            href="tel:+34639810204"
          >
            +34 639 81 02 04
          </a>
          <span class="hidden text-on-surface/25 sm:inline" aria-hidden="true">·</span>
          <a
            class="font-label text-[11px] font-semibold uppercase tracking-[0.12em] text-on-surface/85 transition-colors hover:text-primary md:text-xs"
            href="tel:+34623997930"
          >
            +34 623 99 79 30
          </a>
        </div>
        <a
          class="metallic-gradient text-on-primary font-label font-bold rounded-lg px-4 py-2 text-[10px] uppercase tracking-widest shadow-[0_0_18px_rgba(242,202,80,0.18)] transition-[filter,transform] btn-hover-strong hover:brightness-105 md:px-6 md:py-2.5 md:text-xs whitespace-nowrap"
          href="/#reservas"
        >
          Reservar mesa
        </a>
      </div>
    </div>

    <!-- Fila principal -->
    <div class="glass-nav">
      <div class="relative flex w-full max-w-7xl mx-auto items-center px-5 md:px-8 py-4 md:py-6">
        <div class="flex min-w-0 flex-1 justify-start">
          <a
            class="header-logo shrink-0 rounded-lg p-2 hover:brightness-[1.02]"
            href="/"
            aria-label="Sabor y Salsa inicio"
          >
            <img
              alt="Sabor &amp; Salsa Logo"
              class="block h-[3.25rem] w-auto md:h-[4rem] lg:h-[4.25rem] max-w-[min(100vw-8rem,440px)] object-contain"
              decoding="async"
              fetchpriority="high"
              src="/logo.png"
            />
          </a>
        </div>
        <div
          class="pointer-events-none absolute left-1/2 top-1/2 z-10 hidden -translate-x-1/2 -translate-y-1/2 md:flex min-w-0 items-center justify-center gap-10"
        >
          {links.map((link) => (
            <a
              class={`pointer-events-auto font-label uppercase tracking-wider text-xs font-bold spark-underline ${activeLink === link.label ? "text-primary border-primary pb-1 nav-item-active" : "text-on-surface/80 nav-link-hover"}`}
              href={link.href}
            >
              {link.label}
            </a>
          ))}
        </div>
        <div class="flex h-11 w-11 shrink-0 items-center justify-end">
          <button
            aria-controls="mobile-menu"
            aria-expanded="false"
            class="md:hidden w-11 h-11 shrink-0 rounded-lg border border-primary/20 text-primary flex items-center justify-center"
            id="mobile-menu-toggle"
            type="button"
          >
            <span class="material-symbols-outlined">menu</span>
          </button>
        </div>
      </div>
    </div>
  </div>

  <div
    class="md:hidden fixed left-0 right-0 z-40 hidden overflow-y-auto bg-surface"
    id="mobile-menu"
  >
    <div class="flex min-h-full flex-col items-center justify-center w-full p-4 space-y-6">
      {links.map((link) => (
        <a
          class={`block py-3 text-sm uppercase tracking-[0.2em] text-center ${activeLink === link.label ? "text-primary spark-underline nav-item-active" : "text-on-surface/80 nav-link-hover"}`}
          href={link.href}
        >
          {link.label}
        </a>
      ))}
    </div>
  </div>
</nav>

<script>
  const mobileToggle = document.getElementById("mobile-menu-toggle");
  const mobileMenu = document.getElementById("mobile-menu");
  const navStack = document.getElementById("site-nav-stack");

  function syncNavLayout() {
    if (!navStack) return;
    const h = navStack.getBoundingClientRect().height;
    document.documentElement.style.setProperty("--site-header-height", `${h}px`);
    if (!mobileMenu) return;
    mobileMenu.style.top = `${h}px`;
    mobileMenu.style.height = `calc(100dvh - ${h}px)`;
  }

  if (mobileToggle && mobileMenu) {
    mobileToggle.addEventListener("click", () => {
      const expanded = mobileToggle.getAttribute("aria-expanded") === "true";
      mobileToggle.setAttribute("aria-expanded", String(!expanded));
      mobileMenu.classList.toggle("hidden");
      if (!mobileMenu.classList.contains("hidden")) syncNavLayout();
    });

    mobileMenu.querySelectorAll("a").forEach((link) => {
      link.addEventListener("click", () => {
        mobileMenu.classList.add("hidden");
        mobileToggle.setAttribute("aria-expanded", "false");
      });
    });
  }

  window.addEventListener("resize", syncNavLayout);
  syncNavLayout();
</script>
