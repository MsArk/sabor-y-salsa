---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Nav from "@/shared/components/Nav.astro";
import Footer from "@/shared/components/Footer.astro";
import LocationMapEmbed from "@/shared/components/LocationMapEmbed.astro";
import MenuCartaCarousel from "@/features/carta/components/MenuCartaCarousel";
import {
  calientesSlides,
  entrantesSlides,
} from "@/features/carta/data/carta-carousel-slides";

/** Producción Webhook URL del flujo n8n (nodo Webhook). */
const reservationN8nWebhookUrl =
  typeof import.meta.env.PUBLIC_N8N_RESERVA_WEBHOOK_URL === "string"
    ? import.meta.env.PUBLIC_N8N_RESERVA_WEBHOOK_URL.trim()
    : "";

/** Franjas HH:MM (24h) mostradas en el formulario de reserva — alineadas con Lun–Dom · 12:00–00:00. */
const reservationSlotsComida = [
  "12:00",
  "12:30",
  "13:00",
  "13:30",
  "14:00",
  "14:30",
  "15:00",
  "15:30",
  "16:00",
  "16:30",
  "17:00",
] as const;
const reservationSlotsCena = [
  "19:30",
  "20:00",
  "20:30",
  "21:00",
  "21:30",
  "22:00",
  "22:30",
  "23:00",
] as const;
---

<BaseLayout title="Sabor &amp; Salsa | Premium Peruvian Street Food">
  <Nav />
  <main>
    <!-- Hero Section -->
    <section
      class="relative flex min-h-[100dvh] items-center justify-center overflow-x-hidden px-0 pb-8 pt-[var(--site-header-height)] md:pb-12"
      id="inicio"
    >
      <div class="absolute inset-0 z-0 overflow-hidden">
        <img alt="Sabor &amp; Salsa Interior" class="w-full h-full object-cover opacity-60 scale-105"
          src="/img/hero-interior.jpg" />
        <div class="absolute inset-0 bg-gradient-to-b from-surface/40 via-surface/60 to-surface"></div>
        <div class="hero-burst-orb o1" aria-hidden="true"></div>
        <div class="hero-burst-orb o2" aria-hidden="true"></div>
        <div class="meteor m1" style="top: 18%; right: 12%" aria-hidden="true"></div>
        <div class="meteor m2" aria-hidden="true"></div>
        <div class="meteor m3" aria-hidden="true"></div>
      </div>
      <div class="relative z-10 text-center max-w-4xl px-6 mt-6 reveal in">
        <span class="font-label text-primary uppercase tracking-[0.4em] text-xs mb-6 block">Est. Lima <span data-current-year></span></span>
        <h1 class="hero-title font-headline text-6xl md:text-8xl lg:text-9xl font-bold text-on-surface leading-none tracking-tighter mb-8">
          SABOR <span class="italic font-normal text-primary">&amp;</span> SALSA
        </h1>
        <p class="font-body text-[24px] text-on-surface-variant max-w-2xl mx-auto mb-12 leading-relaxed">
          El autentico sabor del Perú, <br/> llega a tu mesa hecho con mucho <span
            class="text-on-surface font-semibold italic">sabor</span> y <span
            class="text-on-surface font-semibold italic">pasión</span>.
        </p>
        <div class="flex flex-col md:flex-row items-center justify-center gap-6">
          <a class="hero-cta metallic-gradient text-on-primary font-label font-bold px-10 py-4 rounded-lg uppercase tracking-widest btn-hover-strong"
            href="#reservas">
            Reservar Mesa
          </a>
          <a class="bg-transparent border border-outline-variant/30 text-primary font-label font-bold px-10 py-4 rounded-lg uppercase tracking-widest btn-hover-soft"
            href="#carta">
            Nuestra Carta
          </a>
        </div>
      </div>
    </section>

    <!-- Manifiesto -->
    <section class="py-20 md:py-24 bg-surface-container-high reveal" id="manifiesto" style="--reveal-delay: 70ms">
      <div class="max-w-7xl mx-auto px-5 md:px-8 grid grid-cols-1 lg:grid-cols-12 gap-8 items-center">
        <div class="lg:col-span-8">
          <span class="font-label text-primary uppercase tracking-[0.3em] text-[10px] font-bold">Manifiesto</span>
          <h2 class="font-headline text-4xl md:text-6xl font-bold mt-4 mb-6 leading-tight">Nacimos en el Callao.
            Latinos en Madrid: <span class="italic text-primary font-normal">fuego, alma y calle</span></h2>
          <p class="text-on-surface-variant text-lg leading-relaxed max-w-3xl">No cocinamos pollo. Domamos el fuego.
            Cada brasa lleva el ADN de las calles del Callao, donde aprendimos que lo auténtico no se disfraza.
            Aquí el sabor habla fuerte, la tradición manda y el humo cuenta historias que no se olvidan.</p>
        </div>
      </div>
    </section>

    <!-- Featured Dish: Pollo a la Brasa -->
    <section class="py-24 md:py-32 bg-surface reveal" id="pollo" style="--reveal-delay: 120ms">
      <div class="max-w-7xl mx-auto px-5 md:px-8 flex flex-col lg:flex-row items-center gap-12 lg:gap-20">
        <div class="w-full lg:w-1/2 relative group">
          <div class="absolute -inset-4 bg-primary/10 rounded-xl blur-2xl group-hover:bg-primary/20 transition-all duration-700"></div>
          <img alt="Pollo a la Brasa" class="relative rounded-xl w-full h-[400px] md:h-[600px] object-cover shadow-2xl"
            src="/img/pollo-brasa.png" />
          <div class="absolute top-8 left-8 bg-secondary-container text-on-secondary-container px-4 py-2 font-label text-[10px] font-extrabold uppercase tracking-widest rounded-full">
            Chef's Masterpiece
          </div>
        </div>
        <div class="w-full lg:w-1/2">
          <h2 class="font-headline text-4xl md:text-5xl font-bold mb-8 leading-tight">El Pollo <br /><span
              class="text-primary italic font-normal">a la Brasa Real</span></h2>
          <p class="font-body text-on-surface-variant text-lg leading-relaxed mb-10 italic border-l-2 border-primary/30 pl-6">
            "Raíces peruanas, fuego lento y sabor que deja huella."
          </p>
          <div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-8">
            <div class="bg-surface-container-low p-6 rounded-xl border border-outline-variant/10 menu-option-card">
              <span class="font-label text-on-surface-variant text-[10px] uppercase tracking-widest mb-2 block">Cuarto</span>
              <div class="text-2xl font-headline font-bold text-primary">13 €</div>
            </div>
            <div class="bg-surface-container-low p-6 rounded-xl border border-outline-variant/10 menu-option-card">
              <span class="font-label text-on-surface-variant text-[10px] uppercase tracking-widest mb-2 block">Medio</span>
              <div class="text-2xl font-headline font-bold text-primary">18 €</div>
            </div>
            <div class="bg-surface-container-high p-6 rounded-xl border border-primary/30 ring-1 ring-primary/20 menu-option-card">
              <span class="font-label text-primary text-[10px] uppercase tracking-widest mb-2 block">Entero</span>
              <div class="text-2xl font-headline font-bold text-primary">33 €</div>
            </div>
          </div>
          <div class="bg-surface-container-low rounded-xl border border-outline-variant/10 p-5 mb-8">
            <h4 class="font-label text-primary uppercase tracking-[0.18em] text-[10px] mb-3">Salsas caseras</h4>
            <div class="flex flex-wrap gap-3 text-sm text-on-surface">
              <span class="px-3 py-2 rounded-lg border border-outline-variant/20 menu-option-card">Aji pollero</span>
              <span class="px-3 py-2 rounded-lg border border-outline-variant/20 menu-option-card">Crema de rocoto</span>
              <span class="px-3 py-2 rounded-lg border border-outline-variant/20 menu-option-card">Rocoto</span>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Menu Highlights: Bento Grid Style -->
    <section class="py-24 md:py-32 bg-surface-container-low reveal" id="carta" style="--reveal-delay: 150ms">
      <div class="max-w-7xl mx-auto px-5 md:px-8">
        <div class="flex justify-between items-end mb-16">
          <div>
            <span class="font-label text-primary uppercase tracking-[0.3em] text-[10px] font-bold">La Seleccion</span>
            <h2 class="font-headline text-5xl font-bold mt-4">Nuestra Carta</h2>
          </div>
          <p class="font-body text-on-surface-variant max-w-xs text-right hidden md:block">
            Un viaje sensorial por los distritos gastronomicos de Lima.
          </p>
        </div>
        <div class="grid grid-cols-1 lg:grid-cols-2 lg:items-stretch gap-6">
          <!-- Entrantes -->
          <div class="lg:h-full min-h-0 min-w-0 bg-surface-container-high p-5 sm:p-8 rounded-xl flex flex-col glow-card">
            <div class="h-48 mb-6 overflow-hidden rounded-lg shrink-0">
              <img alt="Entrantes" class="w-full h-full object-cover" src="/img/entrantes.png" />
            </div>
            <div>
              <h3 class="font-headline text-2xl font-bold mb-2">ENTRANTES</h3>
              <span class="carta-chip carta-chip--entrantes">Para empezar el ritmo</span>
              <MenuCartaCarousel
                client:visible
                slides={entrantesSlides}
                ariaLabel="Lista de entrantes"
                prevLabel="Entrantes anteriores"
                nextLabel="Entrantes siguientes"
              />
            </div>
          </div>
          <!-- Platos Calientes -->
          <div class="lg:h-full min-h-0 min-w-0 bg-surface-container-high p-5 sm:p-8 rounded-xl flex flex-col glow-card">
            <div class="h-48 mb-6 overflow-hidden rounded-lg shrink-0">
              <img alt="Platos Calientes - Street Food Latino" class="w-full h-full object-cover transition-transform duration-500 hover:scale-[1.02]"
                src="/img/platos-calientes.png" />
            </div>
            <div>
              <h3 class="font-headline text-2xl font-bold mb-2 text-on-surface">PLATOS CALIENTES</h3>
              <span class="carta-chip carta-chip--calientes">Fuego en cocina</span>
              <MenuCartaCarousel
                client:visible
                slides={calientesSlides}
                ariaLabel="Lista de platos calientes"
                prevLabel="Platos calientes anteriores"
                nextLabel="Platos calientes siguientes"
              />
            </div>
          </div>
          <!-- Platos Fríos -->
          <div class="lg:h-full min-h-0 min-w-0 bg-surface-container-high p-5 sm:p-8 rounded-xl flex flex-col glow-card">
            <div class="h-48 mb-6 overflow-hidden rounded-lg shrink-0">
              <img alt="Platos Fríos - Ceviches y Tiraditos" class="w-full h-full object-cover transition-transform duration-500 hover:scale-[1.02]"
                src="/img/platos-frios.png" />
            </div>
            <div>
              <h3 class="font-headline text-2xl font-bold mb-2 text-on-surface">PLATOS FRÍOS</h3>
              <span class="carta-chip carta-chip--frios">Del mar a la mesa</span>
              <div class="space-y-3">
                <div class="grid grid-cols-[minmax(0,1fr)_auto] gap-x-3 items-start menu-option-card rounded-lg py-2 border border-transparent">
                  <div class="min-w-0">
                    <h3 class="font-headline text-xl font-bold text-on-surface mb-1">Ceviche clásico personal</h3>
                    <p class="font-body text-sm text-on-surface-variant">Pescado marinado en jugo de limón, cebolla y especias.</p>
                  </div>
                  <span class="font-headline text-cyan-400 font-bold shrink-0">22,5 €</span>
                </div>
                <div class="grid grid-cols-[minmax(0,1fr)_auto] gap-x-3 items-start menu-option-card rounded-lg py-2 border border-transparent">
                  <div class="min-w-0">
                    <h3 class="font-headline text-xl font-bold text-on-surface mb-1">Ceviche clásico familiar</h3>
                    <p class="font-body text-sm text-on-surface-variant">Pescado marinado en jugo de limón, cebolla y especias.</p>
                  </div>
                  <span class="font-headline text-cyan-400 font-bold shrink-0">70 €</span>
                </div>
                <div class="grid grid-cols-[minmax(0,1fr)_auto] gap-x-3 items-start menu-option-card rounded-lg py-2 border border-transparent">
                  <div class="min-w-0">
                    <h3 class="font-headline text-xl font-bold text-on-surface mb-1">Ceviche mixto personal</h3>
                    <p class="font-body text-sm text-on-surface-variant">Pescado, calamar y camarón marinado en jugo de limón, cebolla y especias.</p>
                  </div>
                  <span class="font-headline text-cyan-400 font-bold shrink-0">25 €</span>
                </div>
                <div class="grid grid-cols-[minmax(0,1fr)_auto] gap-x-3 items-start menu-option-card rounded-lg py-2 border border-transparent">
                  <div class="min-w-0">
                    <h3 class="font-headline text-xl font-bold text-on-surface mb-1">Ceviche mixto familiar</h3>
                    <p class="font-body text-sm text-on-surface-variant">Pescado, calamar y camarón marinado en jugo de limón, cebolla y especias.</p>
                  </div>
                  <span class="font-headline text-cyan-400 font-bold shrink-0">75 €</span>
                </div>
              </div>
            </div>
          </div>
          <!-- Postres -->
          <div class="lg:h-full min-h-0 min-w-0 bg-surface-container-high p-5 sm:p-8 rounded-xl flex flex-col glow-card">
            <div class="h-48 mb-6 overflow-hidden rounded-lg shrink-0">
              <img alt="Postres" class="w-full h-full object-cover transition-transform duration-500 hover:scale-[1.02]"
                src="/img/postres.png" />
            </div>
            <div>
              <h3 class="font-headline text-2xl font-bold mb-2 text-on-surface">POSTRES</h3>
              <span class="carta-chip carta-chip--postres">El gustito</span>
              <div class="space-y-3">
                <div class="grid grid-cols-[minmax(0,1fr)_auto] gap-x-3 items-center menu-option-card rounded-lg py-2 border border-transparent">
                  <span class="font-headline text-lg font-bold text-on-surface">Tres leches</span>
                  <span class="font-headline text-primary font-bold shrink-0">6 €</span>
                </div>
                <div class="grid grid-cols-[minmax(0,1fr)_auto] gap-x-3 items-center menu-option-card rounded-lg py-2 border border-transparent">
                  <span class="font-headline text-lg font-bold text-on-surface">Tarta de chocolate</span>
                  <span class="font-headline text-primary font-bold shrink-0">6 €</span>
                </div>
                <div class="grid grid-cols-[minmax(0,1fr)_auto] gap-x-3 items-center menu-option-card rounded-lg py-2 border border-transparent">
                  <span class="font-headline text-lg font-bold text-on-surface">Tarta helada</span>
                  <span class="font-headline text-primary font-bold shrink-0">6 €</span>
                </div>
                <div class="grid grid-cols-[minmax(0,1fr)_auto] gap-x-3 items-center menu-option-card rounded-lg py-2 border border-transparent">
                  <span class="font-headline text-lg font-bold text-on-surface">Copa de helado</span>
                  <span class="font-headline text-primary font-bold shrink-0">7,5 €</span>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Barra & Cócteles -->
    <section class="py-24 md:py-32 bg-surface text-center reveal" id="barra" style="--reveal-delay: 180ms">
      <div class="max-w-5xl mx-auto px-5 md:px-8">
        <span class="material-symbols-outlined text-primary text-4xl mb-6">local_bar</span>
        <h2 class="font-headline text-5xl font-bold mb-16 italic">El Ritmo Liquido</h2>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-12">
          <div class="space-y-4 glow-card p-4 rounded-xl"></div>
          <div class="space-y-4 pt-12 md:pt-0 glow-card p-4 rounded-xl">
            <div class="relative h-64 mb-6 rounded-xl overflow-hidden shadow-2xl scale-110 border-2 border-primary/20">
              <img alt="Pisco Sour" class="w-full h-full object-cover" src="/img/pisco-sour.png" />
            </div>
            <h4 class="font-headline text-xl font-bold text-primary">Pisco Sour</h4>
            <p class="font-body text-sm text-on-surface-variant">Quebranta, clara de huevo y gotas de amargo.</p>
            <span class="text-primary font-headline font-bold text-lg">10 €</span>
          </div>
          <div class="space-y-4 glow-card p-4 rounded-xl"></div>
        </div>
        <div class="mt-8 grid grid-cols-2 md:grid-cols-4 gap-6 text-left">
          <div class="bg-surface-container-high p-6 rounded-xl glow-card">
            <h5 class="font-label text-primary text-[10px] uppercase tracking-widest mb-3">Copas</h5>
            <ul class="space-y-2 text-sm text-on-surface-variant">
              <li class="menu-option-card rounded px-2 py-1 border border-transparent">Johnnie Walker (black o red)</li>
              <li class="menu-option-card rounded px-2 py-1 border border-transparent">Brugal</li>
              <li class="menu-option-card rounded px-2 py-1 border border-transparent">Barcelo</li>
            </ul>
          </div>
          <div class="bg-surface-container-high p-6 rounded-xl glow-card">
            <h5 class="font-label text-primary text-[10px] uppercase tracking-widest mb-3">Cervezas</h5>
            <ul class="space-y-2 text-sm text-on-surface-variant">
              <li class="menu-option-card rounded px-2 py-1 border border-transparent">Cusqueña</li>
              <li class="menu-option-card rounded px-2 py-1 border border-transparent">Pilsen</li>
              <li class="menu-option-card rounded px-2 py-1 border border-transparent">Heineken</li>
              <li class="menu-option-card rounded px-2 py-1 border border-transparent">Corona</li>
              <li class="menu-option-card rounded px-2 py-1 border border-transparent">Maou</li>
            </ul>
          </div>
          <div class="bg-surface-container-high p-6 rounded-xl glow-card">
            <h5 class="font-label text-primary text-[10px] uppercase tracking-widest mb-3">Vinos</h5>
            <ul class="space-y-2 text-sm text-on-surface-variant">
              <li class="menu-option-card rounded px-2 py-1 border border-transparent">Tintos</li>
              <li class="menu-option-card rounded px-2 py-1 border border-transparent">Blancos</li>
              <li class="menu-option-card rounded px-2 py-1 border border-transparent">Espumantes</li>
            </ul>
          </div>
          <div class="bg-surface-container-high p-6 rounded-xl glow-card">
            <h5 class="font-label text-primary text-[10px] uppercase tracking-widest mb-3">Refrescos</h5>
            <ul class="space-y-2 text-sm text-on-surface-variant">
              <li class="menu-option-card rounded px-2 py-1 border border-transparent">Chicha</li>
              <li class="menu-option-card rounded px-2 py-1 border border-transparent">Maracuya</li>
            </ul>
          </div>
        </div>
      </div>
    </section>

    <!-- Reservas -->
    <section class="py-24 md:py-32 bg-surface-container-low reveal" id="reservas" style="--reveal-delay: 220ms">
      <div class="max-w-7xl mx-auto px-5 md:px-8 grid grid-cols-1 lg:grid-cols-12 gap-8 md:gap-10">
        <div class="lg:col-span-7 bg-surface-container-high p-8 md:p-12 rounded-xl glow-card">
          <span class="font-label text-primary uppercase tracking-[0.28em] text-[11px] mb-4 block">Reservas</span>
          <h2 class="font-headline text-4xl md:text-6xl font-bold leading-tight mb-6">Tus días de <span class="italic text-primary font-normal">alegría</span></h2>
          <p class="text-on-surface-variant leading-relaxed max-w-2xl mb-10">Reservas de lunes a domingo.</p>
          <form class="space-y-6" id="reserva-form" novalidate>
            <div
              id="reserva-form-alert"
              class="hidden rounded-xl border border-error/35 bg-error-container/25 px-4 py-3 text-sm text-on-error-container [&_strong]:font-semibold [&_strong]:text-on-error-container"
              role="alert"
              aria-live="assertive"
              aria-hidden="true"
            ></div>
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
              <label class="block">
                <span class="font-label text-[10px] uppercase tracking-[0.18em] text-on-surface/70">Nombre</span>
                <input id="reserva-nombre"
                  class="mt-2 w-full bg-transparent border-0 border-b border-outline/40 focus:border-primary focus:ring-0 px-1 py-2 text-on-surface placeholder:text-on-surface/35"
                  name="nombre"
                  autocomplete="name"
                  placeholder="Tu nombre" required type="text" />
              </label>
              <label class="block">
                <span class="font-label text-[10px] uppercase tracking-[0.18em] text-on-surface/70">Telefono</span>
                <input id="reserva-telefono"
                  class="mt-2 w-full bg-transparent border-0 border-b border-outline/40 focus:border-primary focus:ring-0 px-1 py-2 text-on-surface placeholder:text-on-surface/35"
                  name="telefono"
                  autocomplete="tel"
                  placeholder="+34 ..." required type="tel" />
              </label>
              <label class="block sm:col-span-2">
                <span class="font-label text-[10px] uppercase tracking-[0.18em] text-on-surface/70">Fecha</span>
                <input id="reserva-fecha"
                  class="mt-2 w-full bg-transparent border-0 border-b border-outline/40 focus:border-primary focus:ring-0 px-1 py-2 text-on-surface sm:max-w-xs"
                  name="fecha" required type="date" />
              </label>
              <div class="sm:col-span-2 space-y-5">
                <div>
                  <span id="reserva-horario-label"
                    class="font-label text-[10px] uppercase tracking-[0.18em] text-on-surface/70 block mb-3">Turno preferido</span>
                  <input id="reserva-hora" name="hora" type="hidden" value="" />
                  <fieldset class="border-0 p-0 m-0 mb-6" aria-describedby="reserva-horario-label">
                    <legend class="font-label text-primary text-[11px] uppercase tracking-[0.2em] mb-3">Comida</legend>
                    <div class="flex flex-wrap gap-2">
                      {reservationSlotsComida.map((h) => (
                        <label class="cursor-pointer outline-none shrink-0">
                          <input
                            type="radio"
                            name="reserva_horario_radio"
                            value={h}
                            class="peer sr-only"
                            data-reserva-slot=""
                          />
                          <span class="block rounded-lg border border-outline/40 px-3 py-2 text-sm font-body text-on-surface transition-colors hover:border-primary/50 peer-checked:border-primary peer-checked:bg-primary/15 peer-checked:text-on-surface peer-focus-visible:ring-2 peer-focus-visible:ring-primary/50 peer-disabled:opacity-35 peer-disabled:cursor-not-allowed">
                            {h}
                          </span>
                        </label>
                      ))}
                    </div>
                  </fieldset>
                  <fieldset class="border-0 p-0 m-0" aria-describedby="reserva-horario-label">
                    <legend class="font-label text-primary text-[11px] uppercase tracking-[0.2em] mb-3">Cena</legend>
                    <div class="flex flex-wrap gap-2">
                      {reservationSlotsCena.map((h) => (
                        <label class="cursor-pointer outline-none shrink-0">
                          <input
                            type="radio"
                            name="reserva_horario_radio"
                            value={h}
                            class="peer sr-only"
                            data-reserva-slot=""
                          />
                          <span class="block rounded-lg border border-outline/40 px-3 py-2 text-sm font-body text-on-surface transition-colors hover:border-primary/50 peer-checked:border-primary peer-checked:bg-primary/15 peer-checked:text-on-surface peer-focus-visible:ring-2 peer-focus-visible:ring-primary/50 peer-disabled:opacity-35 peer-disabled:cursor-not-allowed">
                            {h}
                          </span>
                        </label>
                      ))}
                    </div>
                  </fieldset>
                </div>
              </div>
              <label class="block sm:col-span-2">
                <span class="font-label text-[10px] uppercase tracking-[0.18em] text-on-surface/70">Personas</span>
                <input id="reserva-personas"
                  class="mt-2 w-full bg-transparent border-0 border-b border-outline/40 focus:border-primary focus:ring-0 px-1 py-2 text-on-surface"
                  name="personas"
                  max="12" min="1" required type="number" value="2" />
              </label>
            </div>
            <label class="flex gap-3 items-start cursor-pointer select-none pt-2">
              <input id="reserva-alergico"
                class="mt-1 h-4 w-4 shrink-0 rounded border border-outline-variant/50 bg-transparent text-primary focus:ring-primary"
                name="alergico" type="checkbox" value="1" />
              <span class="font-label text-[10px] uppercase tracking-[0.18em] text-on-surface/70 leading-snug pt-px">
                Hay alguien con <span class="text-on-surface normal-case tracking-normal font-body text-sm">alergias o intolerancias alimentarias</span>
              </span>
            </label>
            <label class="block hidden pt-2" id="reserva-alergias-wrap">
              <span class="font-label text-[10px] uppercase tracking-[0.18em] text-on-surface/70">Detalle de alergias (opcional)</span>
              <textarea id="reserva-alergias-detalle"
                class="mt-2 w-full bg-transparent border-0 border-b border-outline/40 focus:border-primary focus:ring-0 px-1 py-2 text-on-surface placeholder:text-on-surface/35 resize-none min-h-[3rem]"
                name="detalle_alergias" rows="2" placeholder="Indica las alergias o advertencias relevantes para cocina"></textarea>
            </label>
            <div class="pt-4">
              <button id="reserva-submit-btn"
                type="submit"
                class="metallic-gradient text-on-primary font-label font-bold px-8 py-4 rounded-lg uppercase tracking-widest btn-hover-strong disabled:pointer-events-none disabled:opacity-55">
                Confirmar Reserva
              </button>
            </div>
          </form>
        </div>
        <aside class="lg:col-span-5 flex flex-col gap-6 lg:h-full">
          <div class="bg-surface p-8 rounded-xl border border-outline-variant/20 glow-card lg:flex-1">
            <h3 class="font-headline text-3xl font-bold mb-4">Ubicacion</h3>
            <p class="text-on-surface-variant mb-4">
              <a
                class="underline decoration-primary/35 underline-offset-4 transition-colors hover:text-primary hover:decoration-primary"
                href="https://maps.app.goo.gl/qL7hbrxwEwLQjCGH6"
                rel="noopener noreferrer"
                target="_blank"
              >
                Calle Guadaira 14, Local nº 3 Madrid, España
              </a>
            </p>
            <p class="font-label text-[10px] uppercase tracking-[0.18em] text-primary">Lun-Dom · 12PM - 12AM</p>
            <div class="mt-6">
              <LocationMapEmbed />
            </div>
          </div>
        </aside>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>

<script define:vars={{ reservationN8nWebhookUrl, reservationSlotsComida, reservationSlotsCena }}>
  const revealNodes = document.querySelectorAll('.reveal');
  const observer = new IntersectionObserver((entries) => {
    entries.forEach((entry) => {
      if (entry.isIntersecting) {
        entry.target.classList.add('in');
        observer.unobserve(entry.target);
      }
    });
  }, { threshold: 0.2 });
  revealNodes.forEach((node) => observer.observe(node));

  /** Reserva: validación, mensajes en el formulario y envío al webhook (n8n). */
  const reservationForm = document.getElementById('reserva-form');
  const reservationFormAlert = document.getElementById('reserva-form-alert');
  const reservationAlertClassesError =
    'hidden rounded-xl border border-error/35 bg-error-container/25 px-4 py-3 text-sm text-on-error-container [&_strong]:font-semibold [&_strong]:text-on-error-container';
  const reservationAlertClassesSuccess =
    'rounded-xl border border-primary/40 bg-primary/10 px-4 py-3 text-sm text-on-surface [&_strong]:font-semibold';
  const reservationAlertClassesPending =
    'rounded-xl border border-outline/45 bg-surface-container-highest/50 px-4 py-3 text-sm text-on-surface-variant';

  const hideReservationFormAlert = () => {
    if (!(reservationFormAlert instanceof HTMLElement)) return;
    reservationFormAlert.className = reservationAlertClassesError;
    reservationFormAlert.textContent = '';
    reservationFormAlert.setAttribute('aria-hidden', 'true');
  };

  /**
   * @param {{ campo: string; mensaje: string; input?: HTMLElement }[]} issues
   */
  const showReservationFormIssues = (issues) => {
    if (!(reservationFormAlert instanceof HTMLElement)) return;
    reservationFormAlert.className = reservationAlertClassesError.replace(/^hidden /, '');
    reservationFormAlert.classList.remove('hidden');
    reservationFormAlert.removeAttribute('aria-hidden');

    const headline = document.createElement('p');
    headline.className = 'font-label text-[10px] uppercase tracking-widest text-error mb-2';
    headline.textContent = 'No se puede enviar — faltan datos o hay valores no válidos';

    const list = document.createElement('ul');
    list.className = 'list-disc list-inside space-y-1.5 mb-2 pl-0.5';

    const labelForCampo = (c) =>
      ({
        nombre: 'Nombre',
        telefono: 'Teléfono',
        fecha: 'Fecha',
        hora: 'Hora',
        personas: 'Personas',
      })[c] ?? c;

    for (const { campo, mensaje } of issues) {
      const li = document.createElement('li');
      const strong = document.createElement('strong');
      strong.textContent = `${labelForCampo(campo)}: `;
      li.append(strong);
      li.append(document.createTextNode(mensaje));
      list.append(li);
    }

    const footer = document.createElement('p');
    footer.className = 'text-xs opacity-90 border-t border-on-error-container/25 pt-2 mt-2';
    footer.textContent = `Por completar: ${issues.map((x) => labelForCampo(x.campo)).join(', ')}`;

    reservationFormAlert.replaceChildren(headline, list, footer);
  };

  /** Fallo después de pasar validación (webhook / red). No usa la lista tipo “Por completar”. */
  const showReservationSendError = (title, paragraphs) => {
    if (!(reservationFormAlert instanceof HTMLElement)) return;
    reservationFormAlert.className = reservationAlertClassesError.replace(/^hidden /, '');
    reservationFormAlert.classList.remove('hidden');
    reservationFormAlert.removeAttribute('aria-hidden');

    const h = document.createElement('p');
    h.className = 'font-label text-[10px] uppercase tracking-widest text-error mb-2';
    h.textContent = title;

    const box = document.createElement('div');
    box.className = 'space-y-2';
    for (const line of paragraphs) {
      if (!line) continue;
      const p = document.createElement('p');
      p.className = 'text-sm leading-relaxed';
      p.textContent = line;
      box.append(p);
    }

    reservationFormAlert.replaceChildren(h, box);
    reservationFormAlert.scrollIntoView({ block: 'nearest', behavior: 'smooth' });
  };

  /**
   * Respuesta típica del webhook de reservas (n8n / backend).
   * @param {null | { ok?: boolean; message?: string; email_sent?: boolean; calendar_event_created?: boolean }} api
   */
  const showReservationSubmitSuccess = (api) => {
    if (!(reservationFormAlert instanceof HTMLElement)) return;
    reservationFormAlert.className = reservationAlertClassesSuccess;
    reservationFormAlert.removeAttribute('aria-hidden');
    reservationFormAlert.classList.remove('hidden');

    const h = document.createElement('p');
    h.className = 'font-label text-[10px] uppercase tracking-[0.2em] text-primary mb-2';
    h.textContent = 'Reserva enviada';

    const defaultMsg =
      'Tu solicitud se ha registrado correctamente. Si hace falta confirmación, te contactaremos.';
    const mainText =
      api && typeof api.message === 'string' && api.message.trim() ? api.message.trim() : defaultMsg;

    const p = document.createElement('p');
    p.className = 'text-sm leading-relaxed text-on-surface/90';
    p.textContent = mainText;

    const parts = [h, p];

    if (api && typeof api === 'object') {
      const detailLines = [];
      if (typeof api.email_sent === 'boolean') {
        detailLines.push(
          api.email_sent
            ? 'Correo de confirmación enviado.'
            : 'No se pudo enviar el correo automático; si hace falta, te contactaremos.',
        );
      }
      if (typeof api.calendar_event_created === 'boolean') {
        detailLines.push(
          api.calendar_event_created
            ? 'Evento creado en el calendario del restaurante.'
            : 'No se pudo crear el evento en calendario; te avisaremos si hace falta.',
        );
      }
      if (detailLines.length > 0) {
        const ul = document.createElement('ul');
        ul.className = 'mt-3 text-sm leading-relaxed text-on-surface/80 space-y-1.5 list-disc pl-5';
        for (const line of detailLines) {
          const li = document.createElement('li');
          li.textContent = line;
          ul.append(li);
        }
        parts.push(ul);
      }
    }

    reservationFormAlert.replaceChildren(...parts);
    reservationFormAlert.scrollIntoView({ block: 'nearest', behavior: 'smooth' });
  };

  /** Mientras dura la petición al webhook */
  const showReservationSendingStatus = () => {
    if (!(reservationFormAlert instanceof HTMLElement)) return;
    reservationFormAlert.className = reservationAlertClassesPending;
    reservationFormAlert.removeAttribute('aria-hidden');
    reservationFormAlert.classList.remove('hidden');

    const h = document.createElement('p');
    h.className = 'font-label text-[10px] uppercase tracking-[0.2em] text-primary mb-2';
    h.textContent = 'Enviando…';

    const p = document.createElement('p');
    p.className = 'text-sm leading-relaxed text-on-surface/85';
    p.textContent = 'Estamos enviando tu reserva al servidor; no cierres la página.';

    reservationFormAlert.replaceChildren(h, p);
    reservationFormAlert.scrollIntoView({ block: 'nearest', behavior: 'smooth' });
  };
  const allergyCheckbox = document.getElementById('reserva-alergico');
  const allergyWrap = document.getElementById('reserva-alergias-wrap');
  const allergyDetail = document.getElementById('reserva-alergias-detalle');

  const syncReservationAllergyField = () => {
    const show = allergyCheckbox instanceof HTMLInputElement && allergyCheckbox.checked;
    if (allergyWrap instanceof HTMLElement) allergyWrap.classList.toggle('hidden', !show);
    if (!(allergyCheckbox instanceof HTMLInputElement) || !allergyCheckbox.checked) {
      if (allergyDetail instanceof HTMLTextAreaElement) allergyDetail.value = '';
    }
  };

  if (allergyCheckbox instanceof HTMLInputElement)
    allergyCheckbox.addEventListener('change', syncReservationAllergyField);
  syncReservationAllergyField();

  if (reservationForm instanceof HTMLFormElement) {
    const fechaReservation = reservationForm.querySelector('#reserva-fecha');
    const horaHidden = reservationForm.querySelector('#reserva-hora');
    /** Todos los slots en orden HH:MM (24h); coincide con maquetación */
    const RESERVA_SLOTS_TODOS = [...reservationSlotsComida, ...reservationSlotsCena];
    const RESERVA_HORA_DESDE = reservationSlotsComida[0];
    const RESERVA_HORA_HASTA = reservationSlotsCena[reservationSlotsCena.length - 1];
    const RESERVA_SLOTS_SET = new Set(RESERVA_SLOTS_TODOS);

    const getNowHM = () => {
      const d = new Date();
      return `${String(d.getHours()).padStart(2, '0')}:${String(d.getMinutes()).padStart(2, '0')}`;
    };

    /** Desactiva horarios ya pasados si la fecha es hoy; limpia selección inválida y el hidden `hora`. */
    const syncReservationSlotsFromFecha = () => {
      if (!(fechaReservation instanceof HTMLInputElement) || !(horaHidden instanceof HTMLInputElement)) return;
      const todayStr = new Date().toISOString().slice(0, 10);
      const nowHM = getNowHM();
      const slotRadios = reservationForm.querySelectorAll('input[data-reserva-slot][type="radio"]');

      const isToday = fechaReservation.value === todayStr;
      for (const r of slotRadios) {
        if (!(r instanceof HTMLInputElement)) continue;
        const pastToday = isToday && r.value < nowHM;
        r.disabled = pastToday;
        if (pastToday && r.checked) {
          r.checked = false;
          horaHidden.value = '';
        }
      }

      if (isToday && horaHidden.value && horaHidden.value < nowHM) {
        horaHidden.value = '';
        for (const r of slotRadios) {
          if (r instanceof HTMLInputElement) r.checked = false;
        }
      }
    };

    if (fechaReservation instanceof HTMLInputElement && fechaReservation.type === 'date')
      fechaReservation.min = new Date().toISOString().slice(0, 10);

    if (fechaReservation instanceof HTMLInputElement) {
      fechaReservation.addEventListener('input', syncReservationSlotsFromFecha);
      fechaReservation.addEventListener('change', syncReservationSlotsFromFecha);
    }

    reservationForm.addEventListener('change', (ev) => {
      if (!(horaHidden instanceof HTMLInputElement)) return;
      const t = ev.target;
      if (t instanceof HTMLInputElement && t.matches('input[data-reserva-slot]') && t.checked)
        horaHidden.value = t.value;
    });

    syncReservationSlotsFromFecha();

    const reservationSubmitBtn = reservationForm.querySelector('#reserva-submit-btn');

    const setReservationSubmitBusy = (busy) => {
      if (!(reservationSubmitBtn instanceof HTMLButtonElement)) return;
      if (busy) {
        if (!(reservationSubmitBtn.dataset.labelDefault || '').trim())
          reservationSubmitBtn.dataset.labelDefault =
            reservationSubmitBtn.textContent.trim() || 'Confirmar Reserva';
        reservationSubmitBtn.disabled = true;
        reservationSubmitBtn.setAttribute('aria-busy', 'true');
        reservationSubmitBtn.textContent = 'Enviando…';
        return;
      }
      reservationSubmitBtn.disabled = false;
      reservationSubmitBtn.removeAttribute('aria-busy');
      reservationSubmitBtn.textContent =
        reservationSubmitBtn.dataset.labelDefault?.trim() || 'Confirmar Reserva';
    };

    reservationForm.addEventListener('submit', async (submitEv) => {
      submitEv.preventDefault();
      hideReservationFormAlert();
      syncReservationSlotsFromFecha();

      const nombreEl = reservationForm.querySelector('input[name="nombre"]');
      const telEl = reservationForm.querySelector('input[name="telefono"]');
      const fechaEl = reservationForm.querySelector('input[name="fecha"]');
      const horaEl = reservationForm.querySelector('input[name="hora"]');
      const personasEl = reservationForm.querySelector('input[name="personas"]');
      const firstHoraSlotInput = reservationForm.querySelector('input[data-reserva-slot]:not(:disabled)');
      /** @type {{ campo: string; mensaje: string; input?: HTMLElement }[]} */
      const issues = [];

      if (!(nombreEl instanceof HTMLInputElement))
        issues.push({ campo: 'nombre', mensaje: 'Campo nombre no existe en el formulario.' });
      else if (!nombreEl.value.trim())
        issues.push({ campo: 'nombre', mensaje: 'Vacío — indica tu nombre.', input: nombreEl });

      if (!(telEl instanceof HTMLInputElement))
        issues.push({ campo: 'telefono', mensaje: 'Campo teléfono no existe en el formulario.' });
      else if (!telEl.value.trim())
        issues.push({ campo: 'telefono', mensaje: 'Vacío — indica un teléfono de contacto.', input: telEl });

      if (!(fechaEl instanceof HTMLInputElement))
        issues.push({ campo: 'fecha', mensaje: 'Campo fecha no existe en el formulario.' });
      else if (!fechaEl.value)
        issues.push({ campo: 'fecha', mensaje: 'Sin fecha — elige el día de la reserva.', input: fechaEl });
      else if (fechaEl.value < fechaEl.min)
        issues.push({ campo: 'fecha', mensaje: 'La fecha no puede ser anterior a hoy.', input: fechaEl });
      else {
        const todayStrCheck = new Date().toISOString().slice(0, 10);
        if (fechaEl.value === todayStrCheck) {
          const nowHMSubmit = getNowHM();
          if (nowHMSubmit > RESERVA_HORA_HASTA)
            issues.push({
              campo: 'fecha',
              mensaje:
                `Para hoy ya no hay reservas online (último turno disponible hasta las ${RESERVA_HORA_HASTA}). Elige otra fecha.`,
              input: fechaEl,
            });
        }
      }

      if (!(horaEl instanceof HTMLInputElement))
        issues.push({ campo: 'hora', mensaje: 'Campo hora no existe en el formulario.' });
      else if (!horaEl.value.trim())
        issues.push({
          campo: 'hora',
          mensaje: 'Selecciona un horario en Comida o en Cena.',
          input: firstHoraSlotInput instanceof HTMLElement ? firstHoraSlotInput : horaEl,
        });
      else {
        if (!RESERVA_SLOTS_SET.has(horaEl.value))
          issues.push({
            campo: 'hora',
            mensaje: `Elige una hora entre las opciones disponibles (${RESERVA_HORA_DESDE}–${RESERVA_HORA_HASTA}).`,
            input: firstHoraSlotInput instanceof HTMLElement ? firstHoraSlotInput : horaEl,
          });
        const todayStrCheck = new Date().toISOString().slice(0, 10);
        if (fechaEl instanceof HTMLInputElement && fechaEl.value === todayStrCheck) {
          const nowHMSubmit = getNowHM();
          if (horaEl.value < nowHMSubmit)
            issues.push({
              campo: 'hora',
              mensaje: 'Para hoy, elige un horario igual o posterior a la hora actual.',
              input: firstHoraSlotInput instanceof HTMLElement ? firstHoraSlotInput : horaEl,
            });
        }
      }

      let personasNum = NaN;
      if (!(personasEl instanceof HTMLInputElement))
        issues.push({ campo: 'personas', mensaje: 'Campo personas no existe en el formulario.' });
      else {
        personasNum = Number.parseInt(personasEl.value, 10);
        if (!personasEl.value.trim() || Number.isNaN(personasNum))
          issues.push({ campo: 'personas', mensaje: 'Número de personas inválido o vacío.', input: personasEl });
        else if (personasNum < 1)
          issues.push({ campo: 'personas', mensaje: 'Mínimo 1 persona.', input: personasEl });
        else if (personasNum > 12)
          issues.push({ campo: 'personas', mensaje: 'Máximo 12 personas (ajusta si el grupo es mayor por teléfono).', input: personasEl });
      }

      const alergico = allergyCheckbox instanceof HTMLInputElement && allergyCheckbox.checked;
      const detalleAlergias = allergyDetail instanceof HTMLTextAreaElement ? allergyDetail.value.trim() : '';

      if (issues.length > 0) {
        showReservationFormIssues(issues);
        if (reservationFormAlert instanceof HTMLElement)
          reservationFormAlert.scrollIntoView({ block: 'nearest', behavior: 'smooth' });
        const focusEl = issues.find((x) => x.input)?.input;
        if (focusEl) focusEl.focus({ preventScroll: true });
        return;
      }

      const nombreOk = nombreEl.value.trim();
      const telOk = telEl.value.trim();
      const fechaOk = fechaEl.value;
      const horaOk = horaEl.value;

      const payloadN8n = {
        tipo: 'reserva_mesa',
        origen: 'sabor-y-salsa-web',
        enviado_en: new Date().toISOString(),
        nombre: nombreOk,
        telefono: telOk,
        fecha: fechaOk,
        hora: horaOk,
        personas: personasNum,
        alguien_alergico: alergico,
        detalle_alergias: alergico ? (detalleAlergias || null) : null,
      };

      /** @param {string} bodyText */
      const n8nHintFromBody = (bodyText) => {
        const u = bodyText.toLowerCase();
        if (u.includes('respond to webhook'))
          return 'En n8n el flujo necesita un nodo Respond to Webhook enlazado al Webhook (o activa la respuesta automática en el nodo Webhook). Revisa también que la URL sea la de Producción y que el flujo esté activo.';
        return 'Revisa en n8n que el flujo esté activo, que la URL del Webhook sea la correcta y que no falle ningún nodo previo.';
      };

      if (!reservationN8nWebhookUrl) {
        showReservationSendError(
          'No está configurado el envío automático.',
          [
            'Falta la variable PUBLIC_N8N_RESERVA_WEBHOOK_URL en el entorno donde se construye el sitio (por ejemplo «.env»).',
            'Define la URL de producción del Webhook en n8n y vuelve a generar la web.',
          ],
        );
        return;
      }

      showReservationSendingStatus();
      setReservationSubmitBusy(true);

      try {
        const resN8n = await fetch(reservationN8nWebhookUrl, {
          method: 'POST',
          mode: 'cors',
          headers: { 'Content-Type': 'application/json', Accept: 'application/json' },
          body: JSON.stringify(payloadN8n),
        });
        const bodyText = await resN8n.text().catch(() => '');
        /** @type {null | { ok?: boolean; message?: string; email_sent?: boolean; calendar_event_created?: boolean }} */
        let reservaJson = null;
        if (bodyText.trim()) {
          try {
            const j = JSON.parse(bodyText);
            if (j && typeof j === 'object' && !Array.isArray(j)) reservaJson = j;
          } catch {
            /* cuerpo no JSON */
          }
        }
        if (!resN8n.ok) {
          let serverMsg = '';
          if (reservaJson && typeof reservaJson.message === 'string') serverMsg = reservaJson.message;
          else serverMsg = bodyText.trim().slice(0, 400);
          const hint = n8nHintFromBody(serverMsg || bodyText);
          showReservationSendError(`No se pudo registrar la reserva (error ${resN8n.status}).`, [serverMsg || 'Respuesta sin detalle del servidor.', hint]);
          return;
        }
        if (reservaJson && reservaJson.ok === false) {
          const serverMsg =
            typeof reservaJson.message === 'string' && reservaJson.message.trim()
              ? reservaJson.message.trim()
              : 'La reserva no se completó.';
          showReservationSendError('No se pudo completar la reserva.', [serverMsg]);
          return;
        }
        showReservationSubmitSuccess(reservaJson);
        reservationForm.reset();
        syncReservationSlotsFromFecha();
        syncReservationAllergyField();
      } catch {
        showReservationSendError(
          'No se pudo conectar con el servidor de reservas.',
          [
            'Comprueba tu conexión; si hay error de red o bloqueador, prueba desde otro navegador.',
            'Si el fallo sigue igual, revisa en n8n la URL del Webhook, CORS y que el workflow esté publicado.',
          ],
        );
      } finally {
        setReservationSubmitBusy(false);
      }
    });
  }

  const reduceMotionMq = window.matchMedia("(prefers-reduced-motion: reduce)");

  const hero = document.getElementById("inicio");
  const orbs = hero ? hero.querySelectorAll(".hero-burst-orb") : [];
  const reducedMotion = reduceMotionMq.matches;
  if (hero && orbs.length && !reducedMotion) {
    window.addEventListener('mousemove', (event) => {
      const x = event.clientX / window.innerWidth - 0.5;
      const y = event.clientY / window.innerHeight - 0.5;
      orbs.forEach((orb, index) => {
        if (!(orb instanceof HTMLElement)) return;
        const factor = index === 0 ? 18 : -20;
        orb.style.transform = `translate3d(${x * factor}px, ${y * factor}px, 0)`;
      });
    });
  }
</script>
