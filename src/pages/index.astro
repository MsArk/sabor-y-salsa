---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Nav from "@/shared/components/Nav.astro";
import Footer from "@/shared/components/Footer.astro";
import LocationMapEmbed from "@/shared/components/LocationMapEmbed.astro";
---

<BaseLayout title="Sabor &amp; Salsa | Premium Peruvian Street Food">
  <Nav />
  <main>
    <!-- Hero Section -->
    <section class="relative h-screen flex items-center justify-center overflow-hidden" id="inicio">
      <div class="absolute inset-0 z-0">
        <img alt="Sabor &amp; Salsa Interior" class="w-full h-full object-cover opacity-60 scale-105"
          src="/img/hero-interior.jpg" />
        <div class="absolute inset-0 bg-gradient-to-b from-surface/40 via-surface/60 to-surface"></div>
        <div class="hero-burst-orb o1" aria-hidden="true"></div>
        <div class="hero-burst-orb o2" aria-hidden="true"></div>
        <div class="meteor m1" style="top: 18%; right: 12%" aria-hidden="true"></div>
        <div class="meteor m2" aria-hidden="true"></div>
        <div class="meteor m3" aria-hidden="true"></div>
      </div>
      <div class="relative z-10 text-center max-w-4xl px-6 reveal in">
        <span class="font-label text-primary uppercase tracking-[0.4em] text-xs mb-6 block">Est. Lima <span data-current-year></span></span>
        <h1 class="hero-title font-headline text-6xl md:text-8xl lg:text-9xl font-bold text-on-surface leading-none tracking-tighter mb-8">
          SABOR <span class="italic font-normal text-primary">&amp;</span> SALSA
        </h1>
        <p class="font-body text-[24px] text-on-surface-variant max-w-2xl mx-auto mb-12 leading-relaxed">
          El autentico sabor del Perú, <br/> llega a tu mesa hecho con mucho <span
            class="text-on-surface font-semibold italic">sabor</span> y <span
            class="text-on-surface font-semibold italic">pasión</span>.
        </p>
        <div class="flex flex-col md:flex-row items-center justify-center gap-6">
          <a class="hero-cta metallic-gradient text-on-primary font-label font-bold px-10 py-4 rounded-lg uppercase tracking-widest btn-hover-strong"
            href="#reservas">
            Reservar Mesa
          </a>
          <a class="bg-transparent border border-outline-variant/30 text-primary font-label font-bold px-10 py-4 rounded-lg uppercase tracking-widest btn-hover-soft"
            href="#carta">
            Nuestra Carta
          </a>
        </div>
      </div>
    </section>

    <!-- Manifiesto -->
    <section class="py-20 md:py-24 bg-surface-container-high reveal" id="manifiesto" style="--reveal-delay: 70ms">
      <div class="max-w-7xl mx-auto px-5 md:px-8 grid grid-cols-1 lg:grid-cols-12 gap-8 items-center">
        <div class="lg:col-span-8">
          <span class="font-label text-primary uppercase tracking-[0.3em] text-[10px] font-bold">Manifiesto</span>
          <h2 class="font-headline text-4xl md:text-6xl font-bold mt-4 mb-6 leading-tight">Nacimos en el Callao.
            Latinos en Madrid: <span class="italic text-primary font-normal">fuego, alma y calle</span></h2>
          <p class="text-on-surface-variant text-lg leading-relaxed max-w-3xl">No cocinamos pollo. Domamos el fuego.
            Cada brasa lleva el ADN de las calles del Callao, donde aprendimos que lo auténtico no se disfraza.
            Aquí el sabor habla fuerte, la tradición manda y el humo cuenta historias que no se olvidan.</p>
        </div>
      </div>
    </section>

    <!-- Featured Dish: Pollo a la Brasa -->
    <section class="py-24 md:py-32 bg-surface reveal" id="pollo" style="--reveal-delay: 120ms">
      <div class="max-w-7xl mx-auto px-5 md:px-8 flex flex-col lg:flex-row items-center gap-12 lg:gap-20">
        <div class="w-full lg:w-1/2 relative group">
          <div class="absolute -inset-4 bg-primary/10 rounded-xl blur-2xl group-hover:bg-primary/20 transition-all duration-700"></div>
          <img alt="Pollo a la Brasa" class="relative rounded-xl w-full h-[400px] md:h-[600px] object-cover shadow-2xl"
            src="/img/pollo-brasa.png" />
          <div class="absolute top-8 left-8 bg-secondary-container text-on-secondary-container px-4 py-2 font-label text-[10px] font-extrabold uppercase tracking-widest rounded-full">
            Chef's Masterpiece
          </div>
        </div>
        <div class="w-full lg:w-1/2">
          <h2 class="font-headline text-4xl md:text-5xl font-bold mb-8 leading-tight">El Pollo <br /><span
              class="text-primary italic font-normal">a la Brasa Real</span></h2>
          <p class="font-body text-on-surface-variant text-lg leading-relaxed mb-10 italic border-l-2 border-primary/30 pl-6">
            "Raíces peruanas, fuego lento y sabor que deja huella."
          </p>
          <div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-8">
            <div class="bg-surface-container-low p-6 rounded-xl border border-outline-variant/10 menu-option-card">
              <span class="font-label text-on-surface-variant text-[10px] uppercase tracking-widest mb-2 block">Cuarto</span>
              <div class="text-2xl font-headline font-bold text-primary">13 €</div>
            </div>
            <div class="bg-surface-container-low p-6 rounded-xl border border-outline-variant/10 menu-option-card">
              <span class="font-label text-on-surface-variant text-[10px] uppercase tracking-widest mb-2 block">Medio</span>
              <div class="text-2xl font-headline font-bold text-primary">18 €</div>
            </div>
            <div class="bg-surface-container-high p-6 rounded-xl border border-primary/30 ring-1 ring-primary/20 menu-option-card">
              <span class="font-label text-primary text-[10px] uppercase tracking-widest mb-2 block">Entero</span>
              <div class="text-2xl font-headline font-bold text-primary">33 €</div>
            </div>
          </div>
          <div class="bg-surface-container-low rounded-xl border border-outline-variant/10 p-5 mb-8">
            <h4 class="font-label text-primary uppercase tracking-[0.18em] text-[10px] mb-3">Salsas caseras</h4>
            <div class="flex flex-wrap gap-3 text-sm text-on-surface">
              <span class="px-3 py-2 rounded-lg border border-outline-variant/20 menu-option-card">Aji pollero</span>
              <span class="px-3 py-2 rounded-lg border border-outline-variant/20 menu-option-card">Crema de rocoto</span>
              <span class="px-3 py-2 rounded-lg border border-outline-variant/20 menu-option-card">Rocoto</span>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Menu Highlights: Bento Grid Style -->
    <section class="py-24 md:py-32 bg-surface-container-low reveal" id="carta" style="--reveal-delay: 150ms">
      <div class="max-w-7xl mx-auto px-5 md:px-8">
        <div class="flex justify-between items-end mb-16">
          <div>
            <span class="font-label text-primary uppercase tracking-[0.3em] text-[10px] font-bold">La Seleccion</span>
            <h2 class="font-headline text-5xl font-bold mt-4">Nuestra Carta</h2>
          </div>
          <p class="font-body text-on-surface-variant max-w-xs text-right hidden md:block">
            Un viaje sensorial por los distritos gastronomicos de Lima.
          </p>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 md:items-stretch gap-6">
          <!-- Entrantes -->
          <div class="md:h-full min-h-0 bg-surface-container-high p-8 rounded-xl flex flex-col glow-card">
            <div class="h-48 mb-6 overflow-hidden rounded-lg shrink-0">
              <img alt="Entrantes" class="w-full h-full object-cover" src="/img/entrantes.png" />
            </div>
            <div>
              <h3 class="font-headline text-2xl font-bold mb-2">ENTRANTES</h3>
              <span class="carta-chip carta-chip--entrantes">Para empezar el ritmo</span>
              <div
                class="menu-carta-carousel"
                role="region"
                aria-roledescription="carrusel"
                aria-label="Lista de entrantes"
                tabindex="0"
                data-menu-carousel
              >
                <div class="menu-carta-carousel__viewport overflow-hidden rounded-lg">
                  <div
                    class="flex items-start transition-transform duration-300 motion-reduce:transition-none"
                    style="transition-timing-function: var(--motion-snap)"
                    data-carousel-track
                  >
                    <div class="min-w-full shrink-0 space-y-3 pr-1" data-carousel-panel>
                      <div class="flex justify-between items-start menu-option-card rounded-lg px-3 py-2 border border-transparent">
                        <div class="max-w-md">
                          <h3 class="font-headline text-xl font-bold text-on-surface mb-1">Tequeños</h3>
                          <p class="font-body text-sm text-on-surface-variant">Crujientes palitos rellenos de queso fundido.</p>
                        </div>
                        <span class="font-headline text-primary font-bold">12 €</span>
                      </div>
                      <div class="flex justify-between items-start menu-option-card rounded-lg px-3 py-2 border border-transparent">
                        <div class="max-w-md">
                          <h3 class="font-headline text-xl font-bold text-on-surface mb-1">Yuca frita</h3>
                          <p class="font-body text-sm text-on-surface-variant">Yuca dorada con salsa huancaina.</p>
                        </div>
                        <span class="font-headline text-primary font-bold">12 €</span>
                      </div>
                      <div class="flex justify-between items-start menu-option-card rounded-lg px-3 py-2 border border-transparent">
                        <div class="max-w-md">
                          <h3 class="font-headline text-xl font-bold text-on-surface mb-1">Porción de alitas</h3>
                          <p class="font-body text-sm text-on-surface-variant">Alitas fritas con patatas fritas.</p>
                        </div>
                        <span class="font-headline text-primary font-bold">15 €</span>
                      </div>
                      <div class="flex justify-between items-start menu-option-card rounded-lg px-3 py-2 border border-transparent">
                        <div class="max-w-md">
                          <h3 class="font-headline text-xl font-bold text-on-surface mb-1">Causa limeña</h3>
                          <p class="font-body text-sm text-on-surface-variant">Papa amarilla con aji amarillo y relleno de pollo.</p>
                        </div>
                        <span class="font-headline text-primary font-bold">15 €</span>
                      </div>
                      <div class="flex justify-between items-start menu-option-card rounded-lg px-3 py-2 border border-transparent">
                        <div class="max-w-md">
                          <h3 class="font-headline text-xl font-bold text-on-surface mb-1">Salchipapas</h3>
                          <p class="font-body text-sm text-on-surface-variant">Patatas fritas con hot dogs y salsas.</p>
                        </div>
                        <span class="font-headline text-primary font-bold">10 €</span>
                      </div>
                    </div>
                    <div class="min-w-full shrink-0 space-y-3 pl-1" data-carousel-panel>
                      <div class="flex justify-between items-start menu-option-card rounded-lg px-3 py-2 border border-transparent">
                        <div class="max-w-md">
                          <h3 class="font-headline text-xl font-bold text-on-surface mb-1">Porción de patatas</h3>
                          <p class="font-body text-sm text-on-surface-variant">Patatas fritas.</p>
                        </div>
                        <span class="font-headline text-primary font-bold">7 €</span>
                      </div>
                      <div class="flex justify-between items-start menu-option-card rounded-lg px-3 py-2 border border-transparent">
                        <div class="max-w-md">
                          <h3 class="font-headline text-xl font-bold text-on-surface mb-1">Porción de arroz</h3>
                          <p class="font-body text-sm text-on-surface-variant">Arroz blanco.</p>
                        </div>
                        <span class="font-headline text-primary font-bold">5 €</span>
                      </div>
                      <div class="flex justify-between items-start menu-option-card rounded-lg px-3 py-2 border border-transparent">
                        <div class="max-w-md">
                          <h3 class="font-headline text-xl font-bold text-on-surface mb-1">Torreznos</h3>
                          <p class="font-body text-sm text-on-surface-variant">Desde Soria a tu estómago.</p>
                        </div>
                        <span class="font-headline text-primary font-bold">12,5 €</span>
                      </div>
                      <div class="flex justify-between items-start menu-option-card rounded-lg px-3 py-2 border border-transparent">
                        <div class="max-w-md">
                          <h3 class="font-headline text-xl font-bold text-on-surface mb-1">Croquetas</h3>
                          <p class="font-body text-sm text-on-surface-variant">Con toque ibérico.</p>
                        </div>
                        <span class="font-headline text-primary font-bold">13 €</span>
                      </div>
                      <div class="flex justify-between items-start menu-option-card rounded-lg px-3 py-2 border border-transparent">
                        <div class="max-w-md">
                          <h3 class="font-headline text-xl font-bold text-on-surface mb-1">Anticuchos</h3>
                          <p class="font-body text-sm text-on-surface-variant">Anticuchos de ternera, acompañados con crema a la Huancaina.</p>
                        </div>
                        <span class="font-headline text-primary font-bold">15 €</span>
                      </div>
                    </div>
                  </div>
                </div>
                <div class="flex items-center justify-between gap-3 mt-6 pt-6 border-t border-outline-variant/15">
                  <button
                    type="button"
                    class="menu-carta-carousel__btn shrink-0 flex h-11 w-11 items-center justify-center rounded-full border border-outline-variant/25 text-primary transition-colors hover:border-primary hover:bg-primary/10 disabled:pointer-events-none disabled:opacity-25 disabled:hover:border-outline-variant/25 disabled:hover:bg-transparent"
                    aria-label="Entrantes anteriores"
                    data-carousel-prev
                  >
                    <span aria-hidden class="material-symbols-outlined text-xl">chevron_left</span>
                  </button>
                  <div class="flex justify-center gap-2 min-h-6 flex-1 mx-2" data-carousel-dots></div>
                  <button
                    type="button"
                    class="menu-carta-carousel__btn shrink-0 flex h-11 w-11 items-center justify-center rounded-full border border-outline-variant/25 text-primary transition-colors hover:border-primary hover:bg-primary/10 disabled:pointer-events-none disabled:opacity-25 disabled:hover:border-outline-variant/25 disabled:hover:bg-transparent"
                    aria-label="Entrantes siguientes"
                    data-carousel-next
                  >
                    <span aria-hidden class="material-symbols-outlined text-xl">chevron_right</span>
                  </button>
                </div>
                <p class="sr-only" aria-live="polite" data-carousel-status aria-atomic="true"></p>
              </div>
            </div>
          </div>
          <!-- Platos Calientes -->
          <div class="md:h-full min-h-0 bg-surface-container-high p-8 rounded-xl flex flex-col glow-card">
            <div class="h-48 mb-6 overflow-hidden rounded-lg shrink-0">
              <img alt="Platos Calientes - Street Food Latino" class="w-full h-full object-cover transition-transform duration-500 hover:scale-[1.02]"
                src="/img/platos-calientes.png" />
            </div>
            <div>
              <h3 class="font-headline text-2xl font-bold mb-2 text-on-surface">PLATOS CALIENTES</h3>
              <span class="carta-chip carta-chip--calientes">Fuego en cocina</span>
              <div
                class="menu-carta-carousel"
                role="region"
                aria-roledescription="carrusel"
                aria-label="Lista de platos calientes"
                tabindex="0"
                data-menu-carousel
              >
                <div class="menu-carta-carousel__viewport overflow-hidden rounded-lg">
                  <div
                    class="flex items-start transition-transform duration-300 motion-reduce:transition-none"
                    style="transition-timing-function: var(--motion-snap)"
                    data-carousel-track
                  >
                    <div class="min-w-full shrink-0 space-y-3 pr-1" data-carousel-panel>
                      <div class="flex justify-between items-start menu-option-card rounded-lg px-3 py-2 border border-transparent">
                        <div class="max-w-md">
                          <h3 class="font-headline text-xl font-bold text-on-surface mb-1">Lomo Saltado</h3>
                          <p class="font-body text-sm text-on-surface-variant">Wok a fuego extremadamente alto (punto de humo).</p>
                        </div>
                        <span class="font-headline text-primary font-bold shrink-0">22 €</span>
                      </div>
                      <div class="flex justify-between items-start menu-option-card rounded-lg px-3 py-2 border border-transparent">
                        <div class="max-w-md">
                          <h3 class="font-headline text-xl font-bold text-on-surface mb-1">Chaufa de Pollo</h3>
                          <p class="font-body text-sm text-on-surface-variant">Delicioso arroz fusión peruana-oriental.</p>
                        </div>
                        <span class="font-headline text-primary font-bold shrink-0">18 €</span>
                      </div>
                      <div class="flex justify-between items-start menu-option-card rounded-lg px-3 py-2 border border-transparent">
                        <div class="max-w-md">
                          <h3 class="font-headline text-xl font-bold text-on-surface mb-1">Chaufa de Carne</h3>
                          <p class="font-body text-sm text-on-surface-variant">Delicioso arroz fusión peruana-oriental.</p>
                        </div>
                        <span class="font-headline text-primary font-bold shrink-0">20 €</span>
                      </div>
                      <div class="flex justify-between items-start menu-option-card rounded-lg px-3 py-2 border border-transparent">
                        <div class="max-w-md">
                          <h3 class="font-headline text-xl font-bold text-on-surface mb-1">Chaufa de Marisco</h3>
                          <p class="font-body text-sm text-on-surface-variant">Fusión peruana-oriental. Con sabor peruano.</p>
                        </div>
                        <span class="font-headline text-primary font-bold shrink-0">25 €</span>
                      </div>
                      <div class="flex justify-between items-start menu-option-card rounded-lg px-3 py-2 border border-transparent">
                        <div class="max-w-md">
                          <h3 class="font-headline text-xl font-bold text-on-surface mb-1">Arroz con Marisco</h3>
                          <p class="font-body text-sm text-on-surface-variant">Tipico arroz peruano con mixtura de marisco.</p>
                        </div>
                        <span class="font-headline text-primary font-bold shrink-0">25 €</span>
                      </div>
                    </div>
                    <div class="min-w-full shrink-0 space-y-3 px-1" data-carousel-panel>
                      <div class="flex justify-between items-start menu-option-card rounded-lg px-3 py-2 border border-transparent">
                        <div class="max-w-md">
                          <h3 class="font-headline text-xl font-bold text-on-surface mb-1">Duo Marino</h3>
                          <p class="font-body text-sm text-on-surface-variant">Cheviche de pescado y con chicharron de pescado.</p>
                        </div>
                        <span class="font-headline text-primary font-bold shrink-0">25 €</span>
                      </div>
                      <div class="flex justify-between items-start menu-option-card rounded-lg px-3 py-2 border border-transparent">
                        <div class="max-w-md">
                          <h3 class="font-headline text-xl font-bold text-on-surface mb-1">Trio Marino</h3>
                          <p class="font-body text-sm text-on-surface-variant">Tres deliciosas versiones de nuestro mar.</p>
                        </div>
                        <span class="font-headline text-primary font-bold shrink-0">35 €</span>
                      </div>
                      <div class="flex justify-between items-start menu-option-card rounded-lg px-3 py-2 border border-transparent">
                        <div class="max-w-md">
                          <h3 class="font-headline text-xl font-bold text-on-surface mb-1">Parrilla</h3>
                          <p class="font-body text-sm text-on-surface-variant">Nuestra típica parrilla con mixturas pollo, chuletas de cerdo, filetes de ternera, anticuchos y patatas a la parrilla.</p>
                        </div>
                        <span class="font-headline text-primary font-bold shrink-0">40 €</span>
                      </div>
                      <div class="flex justify-between items-start menu-option-card rounded-lg px-3 py-2 border border-transparent">
                        <div class="max-w-md">
                          <h3 class="font-headline text-xl font-bold text-on-surface mb-1">Jalea personal</h3>
                          <p class="font-body text-sm text-on-surface-variant">Crocantes trozos de pescado con yuquitas fritas y nuestra deciciosa salsa criolla de cebolla.</p>
                        </div>
                        <span class="font-headline text-primary font-bold shrink-0">25 €</span>
                      </div>
                      <div class="flex justify-between items-start menu-option-card rounded-lg px-3 py-2 border border-transparent">
                        <div class="max-w-md">
                          <h3 class="font-headline text-xl font-bold text-on-surface mb-1">Jalea mixta personal</h3>
                          <p class="font-body text-sm text-on-surface-variant">Crocantes trozos de pescado, aros de calamar y camarones empanizados con yuquitas fritas y su nuestra deciciosa salsa criolla de cebolla.</p>
                        </div>
                        <span class="font-headline text-primary font-bold shrink-0">28 €</span>
                      </div>
                    </div>
                    <div class="min-w-full shrink-0 space-y-3 px-1" data-carousel-panel>
                      <div class="flex justify-between items-start menu-option-card rounded-lg px-3 py-2 border border-transparent">
                        <div class="max-w-md">
                          <h3 class="font-headline text-xl font-bold text-on-surface mb-1">Jalea mixta familiar</h3>
                          <p class="font-body text-sm text-on-surface-variant">Crocantes trozos de pescado, aros de calamar y camarones empanizados con yuquitas fritas y su nuestra deciciosa salsa criolla de cebolla.</p>
                        </div>
                        <span class="font-headline text-primary font-bold shrink-0">80 €</span>
                      </div>
                      <div class="flex justify-between items-start menu-option-card rounded-lg px-3 py-2 border border-transparent">
                        <div class="max-w-md">
                          <h3 class="font-headline text-xl font-bold text-on-surface mb-1">Jalea familiar</h3>
                          <p class="font-body text-sm text-on-surface-variant">Crocantes trozos de pescado con yuquitas fritas y nuestra deciciosa salsa criolla de cebolla.</p>
                        </div>
                        <span class="font-headline text-primary font-bold shrink-0">77,5 €</span>
                      </div>
                      <div class="flex justify-between items-start menu-option-card rounded-lg px-3 py-2 border border-transparent">
                        <div class="max-w-md">
                          <h3 class="font-headline text-xl font-bold text-on-surface mb-1">Mostrito</h3>
                          <p class="font-body text-sm text-on-surface-variant">Cuarto de pollo a la brasa, patatas fritas y su rico chaufa.</p>
                        </div>
                        <span class="font-headline text-primary font-bold shrink-0">20 €</span>
                      </div>
                      <div class="flex justify-between items-start menu-option-card rounded-lg px-3 py-2 border border-transparent">
                        <div class="max-w-md">
                          <h3 class="font-headline text-xl font-bold text-on-surface mb-1">Pollada peruana</h3>
                          <p class="font-body text-sm text-on-surface-variant">Deliciosa pollada acompañada de sus patatas a la parrilla, ensalda y cremas.</p>
                        </div>
                        <span class="font-headline text-primary font-bold shrink-0">20 €</span>
                      </div>
                      <div class="flex justify-between items-start menu-option-card rounded-lg px-3 py-2 border border-transparent">
                        <div class="max-w-md">
                          <h3 class="font-headline text-xl font-bold text-on-surface mb-1">Pollo broster</h3>
                          <p class="font-body text-sm text-on-surface-variant">Crujiente pollo broster, acompañada de patatas fritas, ensalda y cremas.</p>
                        </div>
                        <span class="font-headline text-primary font-bold shrink-0">20 €</span>
                      </div>
                    </div>
                    <div class="min-w-full shrink-0 space-y-3 pl-1" data-carousel-panel>
                      <div class="flex justify-between items-start menu-option-card rounded-lg px-3 py-2 border border-transparent">
                        <div class="max-w-md">
                          <h3 class="font-headline text-xl font-bold text-on-surface mb-1">Entrecot</h3>
                          <p class="font-body text-sm text-on-surface-variant">Delicioso entrocot acompañado de patatas a la parilla y cremas.</p>
