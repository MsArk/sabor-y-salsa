<script define:vars={{ reservationN8nWebhookUrl }}>
  const revealNodes = document.querySelectorAll('.reveal');
  const observer = new IntersectionObserver((entries) => {
    entries.forEach((entry) => {
      if (entry.isIntersecting) {
        entry.target.classList.add('in');
        observer.unobserve(entry.target);
      }
    });
  }, { threshold: 0.2 });
  revealNodes.forEach((node) => observer.observe(node));

  /** Reserva: validación, logs en consola y envío por WhatsApp */
  const reservationForm = document.getElementById('reserva-form');
  const allergyCheckbox = document.getElementById('reserva-alergico');
  const allergyWrap = document.getElementById('reserva-alergias-wrap');
  const allergyDetail = document.getElementById('reserva-alergias-detalle');
  const RESERVATION_WA = '34639810204';

  const syncReservationAllergyField = () => {
    const show = allergyCheckbox instanceof HTMLInputElement && allergyCheckbox.checked;
    if (allergyWrap instanceof HTMLElement) allergyWrap.classList.toggle('hidden', !show);
    if (!(allergyCheckbox instanceof HTMLInputElement) || !allergyCheckbox.checked) {
      if (allergyDetail instanceof HTMLTextAreaElement) allergyDetail.value = '';
    }
  };

  if (allergyCheckbox instanceof HTMLInputElement)
    allergyCheckbox.addEventListener('change', syncReservationAllergyField);
  syncReservationAllergyField();

  if (reservationForm instanceof HTMLFormElement) {
    const fechaReservation = reservationForm.querySelector('#reserva-fecha');
    const horaReservation = reservationForm.querySelector('#reserva-hora');
    /** Horario permitido para reservas (local, HH:MM 24h) */
    const RESERVA_HORA_DESDE = '09:00';
    const RESERVA_HORA_HASTA = '23:00';

    /** Mantiene min/max del input acorde a la fecha: hoy no antes de ahora ni antes de apertura; siempre tope 23:00 */
    const syncReservationHoraMinFromFecha = () => {
      if (!(fechaReservation instanceof HTMLInputElement) || !(horaReservation instanceof HTMLInputElement)) return;
      const todayStr = new Date().toISOString().slice(0, 10);
      horaReservation.max = RESERVA_HORA_HASTA;

      if (fechaReservation.value === todayStr) {
        const d = new Date();
        const nowHM = `${String(d.getHours()).padStart(2, '0')}:${String(d.getMinutes()).padStart(2, '0')}`;
        let efectivo = nowHM > RESERVA_HORA_DESDE ? nowHM : RESERVA_HORA_DESDE;
        if (efectivo > RESERVA_HORA_HASTA) horaReservation.removeAttribute('min');
        else horaReservation.min = efectivo;
      } else if (fechaReservation.value) {
        horaReservation.min = RESERVA_HORA_DESDE;
      } else {
        horaReservation.min = RESERVA_HORA_DESDE;
      }
    };

    if (fechaReservation instanceof HTMLInputElement && fechaReservation.type === 'date')
      fechaReservation.min = new Date().toISOString().slice(0, 10);

    if (fechaReservation instanceof HTMLInputElement) {
      fechaReservation.addEventListener('input', syncReservationHoraMinFromFecha);
      fechaReservation.addEventListener('change', syncReservationHoraMinFromFecha);
    }
    syncReservationHoraMinFromFecha();

    reservationForm.addEventListener('submit', async (submitEv) => {
      submitEv.preventDefault();
      syncReservationHoraMinFromFecha();

      const nombreEl = reservationForm.querySelector('input[name="nombre"]');
      const telEl = reservationForm.querySelector('input[name="telefono"]');
      const fechaEl = reservationForm.querySelector('input[name="fecha"]');
      const horaEl = reservationForm.querySelector('input[name="hora"]');
      const personasEl = reservationForm.querySelector('input[name="personas"]');
      /** @type {{ campo: string; mensaje: string; input?: HTMLElement }[]} */
      const issues = [];

      if (!(nombreEl instanceof HTMLInputElement))
        issues.push({ campo: 'nombre', mensaje: 'Campo nombre no existe en el formulario.' });
      else if (!nombreEl.value.trim())
        issues.push({ campo: 'nombre', mensaje: 'Vacío — indica tu nombre.', input: nombreEl });

      if (!(telEl instanceof HTMLInputElement))
        issues.push({ campo: 'telefono', mensaje: 'Campo teléfono no existe en el formulario.' });
      else if (!telEl.value.trim())
        issues.push({ campo: 'telefono', mensaje: 'Vacío — indica un teléfono de contacto.', input: telEl });

      if (!(fechaEl instanceof HTMLInputElement))
        issues.push({ campo: 'fecha', mensaje: 'Campo fecha no existe en el formulario.' });
      else if (!fechaEl.value)
        issues.push({ campo: 'fecha', mensaje: 'Sin fecha — elige el día de la reserva.', input: fechaEl });
      else if (fechaEl.value < fechaEl.min)
        issues.push({ campo: 'fecha', mensaje: 'La fecha no puede ser anterior a hoy.', input: fechaEl });
      else {
        const todayStrCheck = new Date().toISOString().slice(0, 10);
        if (fechaEl.value === todayStrCheck) {
          const dh = new Date();
          const nowHMSubmit = `${String(dh.getHours()).padStart(2, '0')}:${String(dh.getMinutes()).padStart(2, '0')}`;
          if (nowHMSubmit > RESERVA_HORA_HASTA)
            issues.push({
              campo: 'fecha',
              mensaje:
                'Para hoy ya no hay reservas (el horario permitido llega hasta las 23:00). Elige otra fecha.',
              input: fechaEl,
            });
        }
      }

      if (!(horaEl instanceof HTMLInputElement))
        issues.push({ campo: 'hora', mensaje: 'Campo hora no existe en el formulario.' });
      else if (!horaEl.value)
        issues.push({ campo: 'hora', mensaje: 'Sin hora — elige la hora prevista para la mesa.', input: horaEl });
      else {
        if (horaEl.value < RESERVA_HORA_DESDE || horaEl.value > RESERVA_HORA_HASTA)
          issues.push({ campo: 'hora', mensaje: 'La hora debe estar entre las 9:00 y las 23:00.', input: horaEl });
        const horaMin = horaEl.getAttribute('min');
        if (horaEl.value >= RESERVA_HORA_DESDE && horaEl.value <= RESERVA_HORA_HASTA && horaMin && horaEl.value < horaMin)
          issues.push({ campo: 'hora', mensaje: 'Para hoy, la hora no puede ser anterior a la hora actual.', input: horaEl });
      }

      let personasNum = NaN;
      if (!(personasEl instanceof HTMLInputElement))
        issues.push({ campo: 'personas', mensaje: 'Campo personas no existe en el formulario.' });
      else {
        personasNum = Number.parseInt(personasEl.value, 10);
        if (!personasEl.value.trim() || Number.isNaN(personasNum))
          issues.push({ campo: 'personas', mensaje: 'Número de personas inválido o vacío.', input: personasEl });
        else if (personasNum < 1)
          issues.push({ campo: 'personas', mensaje: 'Mínimo 1 persona.', input: personasEl });
        else if (personasNum > 12)
          issues.push({ campo: 'personas', mensaje: 'Máximo 12 personas (ajusta si el grupo es mayor por teléfono).', input: personasEl });
      }

      const alergico = allergyCheckbox instanceof HTMLInputElement && allergyCheckbox.checked;
      const detalleAlergias = allergyDetail instanceof HTMLTextAreaElement ? allergyDetail.value.trim() : '';

      if (issues.length > 0) {
        console.error('[Reserva] No se envía — faltan datos o hay valores no válidos:');
        for (const { campo, mensaje } of issues)
          console.error(`  • ${campo}: ${mensaje}`);
        console.error('[Reserva] Resumen pendiente:', issues.map((x) => x.campo).join(', '));
        const focusEl = issues.find((x) => x.input)?.input;
        if (focusEl) {
          focusEl.focus({ preventScroll: false });
          focusEl.scrollIntoView({ block: 'center', behavior: 'smooth' });
        }
        return;
      }

      const nombreOk = nombreEl.value.trim();
      const telOk = telEl.value.trim();
      const fechaOk = fechaEl.value;
      const horaOk = horaEl.value;

      const payloadN8n = {
        tipo: 'reserva_mesa',
        origen: 'sabor-y-salsa-web',
        enviado_en: new Date().toISOString(),
        nombre: nombreOk,
        telefono: telOk,
        fecha: fechaOk,
        hora: horaOk,
        personas: personasNum,
        alguien_alergico: alergico,
        detalle_alergias: alergico ? (detalleAlergias || null) : null,
      };

      console.info('[Reserva] Información válida. Enviando solicitud:', payloadN8n);

      if (reservationN8nWebhookUrl) {
        try {
          const resN8n = await fetch(reservationN8nWebhookUrl, {
            method: 'POST',
            mode: 'cors',
            headers: { 'Content-Type': 'application/json', Accept: 'application/json' },
            body: JSON.stringify(payloadN8n),
          });
          if (!resN8n.ok) {
            const bodyText = await resN8n.text().catch(() => '');
            console.error('[Reserva] n8n webhook error HTTP', resN8n.status, bodyText.slice(0, 800));
          } else {
            console.info('[Reserva] Payload recibido por n8n (HTTP', resN8n.status + ').');
          }
        } catch (err) {
          console.error('[Reserva] Fallo de red o CORS al llamar al webhook n8n:', err);
        }
      } else {
        console.warn(
          '[Reserva] Sin PUBLIC_N8N_RESERVA_WEBHOOK_URL — configura la URL del Webhook en .env para enviar datos a n8n.',
        );
      }

      const bodyLines = [
        'Hola, quiero reservar mesa en Sabor & Salsa.',
        '',
        `Nombre: ${nombreOk}`,
        `Teléfono: ${telOk}`,
        `Fecha: ${fechaOk}`,
        `Hora: ${horaOk}`,
        `Personas: ${personasNum}`,
        ...(alergico
          ? [
              '',
              `Alergias / intolerancias: sí${detalleAlergias ? `. ${detalleAlergias}` : ''}`,
            ]
          : []),
      ];

      window.open(`https://wa.me/${RESERVATION_WA}?text=${encodeURIComponent(bodyLines.join('\n'))}`, '_blank', 'noopener,noreferrer');
    });
  }

  const reduceMotionMq = window.matchMedia("(prefers-reduced-motion: reduce)");

  /**
   * Carruseles con bucle visual suave (último ↔ primero): clones del último y primer grupo en el DOM.
   * Si prefers-reduced-motion: ciclo instantáneo sin clones.
   */
  document.querySelectorAll("[data-menu-carousel]").forEach((root) => {
    const track = root.querySelector("[data-carousel-track]");
    const prev = root.querySelector("[data-carousel-prev]");
    const next = root.querySelector("[data-carousel-next]");
    const dotsContainer = root.querySelector("[data-carousel-dots]");
    const status = root.querySelector("[data-carousel-status]");
    const originals = track ? [...track.querySelectorAll("[data-carousel-panel]")] : [];

    if (!(track instanceof HTMLElement) || !(prev instanceof HTMLButtonElement) || !(next instanceof HTMLButtonElement) || !dotsContainer || originals.length === 0)
      return;

    const total = originals.length;
    const useSmoothLoop = total >= 2 && !reduceMotionMq.matches;

    if (useSmoothLoop) {
      const cloneLast = originals[total - 1].cloneNode(true);
      const cloneFirst = originals[0].cloneNode(true);
      for (const c of [cloneLast, cloneFirst]) {
        if (c instanceof HTMLElement) {
          c.removeAttribute("data-carousel-panel");
          c.setAttribute("aria-hidden", "true");
          c.tabIndex = -1;
        }
      }
      track.insertBefore(cloneLast, originals[0]);
      track.appendChild(cloneFirst);
    }

    /** Con bucle suave: DOM 0 clone-último, 1…total reales, total+1 clone-primero */
    let slideDomIndex = useSmoothLoop ? 1 : 0;
    let locked = false;
    const dotButtons = [];

    const viewportEl = root.querySelector(":scope > .menu-carta-carousel__viewport");

    const syncCarouselViewportHeight = () => {
      if (!(viewportEl instanceof HTMLElement) || !(track instanceof HTMLElement)) return;
      const panel = track.children[slideDomIndex];
      if (!(panel instanceof HTMLElement)) {
        viewportEl.style.height = "";
        return;
      }
      viewportEl.style.height = `${Math.ceil(panel.scrollHeight)}px`;
    };

    let resizeTO = 0;
    window.addEventListener(
      "resize",
      () => {
        window.clearTimeout(resizeTO);
        resizeTO = window.setTimeout(syncCarouselViewportHeight, 100);
      },
      { passive: true },
    );

    if (typeof ResizeObserver !== "undefined") {
      const ro = new ResizeObserver(syncCarouselViewportHeight);
      ro.observe(root);
    }

    const logicalStable = () => {
      if (!useSmoothLoop) return Math.max(0, Math.min(total - 1, slideDomIndex));
      if (slideDomIndex === total + 1) return 0;
      if (slideDomIndex === 0) return total - 1;
      return slideDomIndex - 1;
    };

    const announce = () => {
      const logical = logicalStable();
      if (status) status.textContent = `Grupo ${logical + 1} de ${total}`;
      dotButtons.forEach((btn, i) => {
        btn.setAttribute("aria-current", i === logical ? "true" : "false");
      });
    };

    const setTranslate = (domIdx, instant) => {
      const noAnim = instant || reduceMotionMq.matches;
      track.style.transition = noAnim ? "none" : "";
      track.style.transform = `translateX(${-domIdx * 100}%)`;
      slideDomIndex = domIdx;

      const flushHeight = () => {
        requestAnimationFrame(syncCarouselViewportHeight);
      };

      flushHeight();

      if (instant && reduceMotionMq.matches) return;

      if (instant && !reduceMotionMq.matches) {
        void track.offsetHeight;
        requestAnimationFrame(() => {
          track.style.transition = "";
          syncCarouselViewportHeight();
        });
      }
    };

    const onNavigateDone = () => {
      if (useSmoothLoop) {
        if (slideDomIndex === total + 1) setTranslate(1, true);
        else if (slideDomIndex === 0) setTranslate(total, true);
      }
      locked = false;
      announce();
    };

    const goAnimated = (targetDomIdx) => {
      if (locked || targetDomIdx === slideDomIndex) return;
      locked = true;
      setTranslate(targetDomIdx, reduceMotionMq.matches);
      announce();

      if (reduceMotionMq.matches) {
        onNavigateDone();
        return;
      }

      let done = false;
      const handleEnd = (e) => {
        if (done || e.target !== track || e.propertyName !== "transform") return;
        done = true;
        track.removeEventListener("transitionend", handleEnd);
        onNavigateDone();
      };
      track.addEventListener("transitionend", handleEnd);
      window.setTimeout(() => {
        if (done || !locked) return;
        done = true;
        track.removeEventListener("transitionend", handleEnd);
        onNavigateDone();
      }, 340);
    };

    const normalizeIfOnClone = () => {
      if (!useSmoothLoop) return;
      if (slideDomIndex === total + 1) setTranslate(1, true);
      else if (slideDomIndex === 0) setTranslate(total, true);
    };

    for (let i = 0; i < total; i += 1) {
      const b = document.createElement("button");
      b.type = "button";
      b.className = "menu-carta-carousel__dot";
      b.setAttribute("aria-label", `Ir al grupo ${i + 1} de ${total}`);
      const targetLogical = i;
      b.addEventListener("click", () => {
        if (locked) return;

        if (!useSmoothLoop) {
          slideDomIndex = targetLogical;
          setTranslate(slideDomIndex, reduceMotionMq.matches);
          announce();
          return;
        }

        normalizeIfOnClone();

        const targetDom = targetLogical + 1;

        if (slideDomIndex === targetDom) return;

        if (slideDomIndex === total && targetLogical === 0) {
          goAnimated(total + 1);
          return;
        }
        if (slideDomIndex === 1 && targetLogical === total - 1) {
          goAnimated(0);
          return;
        }

        goAnimated(targetDom);
      });

      dotsContainer.appendChild(b);
      dotButtons.push(b);
    }

    const step = (direction) => {
      if (locked || total <= 1) return;

      if (!useSmoothLoop) {
        const wrapsBackward = direction < 0 && slideDomIndex === 0;
        const wrapsForward = direction > 0 && slideDomIndex === total - 1;
        slideDomIndex = (slideDomIndex + direction + total) % total;
        setTranslate(slideDomIndex, wrapsBackward || wrapsForward);
        announce();
        return;
      }

      normalizeIfOnClone();

      if (direction > 0)
        goAnimated(slideDomIndex === total ? total + 1 : slideDomIndex + 1);

      else
        goAnimated(slideDomIndex <= 1 ? 0 : slideDomIndex - 1);
    };

    prev.addEventListener("click", () => step(-1));
    next.addEventListener("click", () => step(1));

    reduceMotionMq.addEventListener("change", () => {
      track.style.transition = reduceMotionMq.matches ? "none" : "";
      locked = false;
    });

    root.addEventListener("keydown", (e) => {
      if (!root.contains(document.activeElement)) return;
      if (e.key === "ArrowRight") {
        e.preventDefault();
        normalizeIfOnClone();
        step(1);
      } else if (e.key === "ArrowLeft") {
        e.preventDefault();
        normalizeIfOnClone();
        step(-1);
      }
    });

    locked = false;
    slideDomIndex = useSmoothLoop ? 1 : 0;
    setTranslate(useSmoothLoop ? 1 : 0, true);
    announce();
    syncCarouselViewportHeight();
  });

  const hero = document.getElementById("inicio");
  const orbs = hero ? hero.querySelectorAll(".hero-burst-orb") : [];
  const reducedMotion = reduceMotionMq.matches;
  if (hero && orbs.length && !reducedMotion) {
    window.addEventListener('mousemove', (event) => {
      const x = event.clientX / window.innerWidth - 0.5;
      const y = event.clientY / window.innerHeight - 0.5;
      orbs.forEach((orb, index) => {
        if (!(orb instanceof HTMLElement)) return;
        const factor = index === 0 ? 18 : -20;
        orb.style.transform = `translate3d(${x * factor}px, ${y * factor}px, 0)`;
      });
    });
  }
</script>
