<script>
  const revealNodes = document.querySelectorAll('.reveal');
  const observer = new IntersectionObserver((entries) => {
    entries.forEach((entry) => {
      if (entry.isIntersecting) {
        entry.target.classList.add('in');
        observer.unobserve(entry.target);
      }
    });
  }, { threshold: 0.2 });
  revealNodes.forEach((node) => observer.observe(node));

  const reduceMotionMq = window.matchMedia("(prefers-reduced-motion: reduce)");

  /**
   * Carruseles con bucle visual suave (último ↔ primero): clones del último y primer grupo en el DOM.
   * Si prefers-reduced-motion: ciclo instantáneo sin clones.
   */
  document.querySelectorAll("[data-menu-carousel]").forEach((root) => {
    const track = root.querySelector("[data-carousel-track]");
    const prev = root.querySelector("[data-carousel-prev]");
    const next = root.querySelector("[data-carousel-next]");
    const dotsContainer = root.querySelector("[data-carousel-dots]");
    const status = root.querySelector("[data-carousel-status]");
    const originals = track ? [...track.querySelectorAll("[data-carousel-panel]")] : [];

    if (!(track instanceof HTMLElement) || !(prev instanceof HTMLButtonElement) || !(next instanceof HTMLButtonElement) || !dotsContainer || originals.length === 0)
      return;

    const total = originals.length;
    const useSmoothLoop = total >= 2 && !reduceMotionMq.matches;

    if (useSmoothLoop) {
      const cloneLast = originals[total - 1].cloneNode(true);
      const cloneFirst = originals[0].cloneNode(true);
      for (const c of [cloneLast, cloneFirst]) {
        if (c instanceof HTMLElement) {
          c.removeAttribute("data-carousel-panel");
          c.setAttribute("aria-hidden", "true");
          c.tabIndex = -1;
        }
      }
      track.insertBefore(cloneLast, originals[0]);
      track.appendChild(cloneFirst);
    }

    /** Con bucle suave: DOM 0 clone-último, 1…total reales, total+1 clone-primero */
    let slideDomIndex = useSmoothLoop ? 1 : 0;
    let locked = false;
    const dotButtons = [];

    const viewportEl = root.querySelector(":scope > .menu-carta-carousel__viewport");

    const syncCarouselViewportHeight = () => {
      if (!(viewportEl instanceof HTMLElement) || !(track instanceof HTMLElement)) return;
      const panel = track.children[slideDomIndex];
      if (!(panel instanceof HTMLElement)) {
        viewportEl.style.height = "";
        return;
      }
      viewportEl.style.height = `${Math.ceil(panel.scrollHeight)}px`;
    };

    let resizeTO = 0;
    window.addEventListener(
      "resize",
      () => {
        window.clearTimeout(resizeTO);
        resizeTO = window.setTimeout(syncCarouselViewportHeight, 100);
      },
      { passive: true },
    );

    if (typeof ResizeObserver !== "undefined") {
      const ro = new ResizeObserver(syncCarouselViewportHeight);
      ro.observe(root);
    }

    const logicalStable = () => {
      if (!useSmoothLoop) return Math.max(0, Math.min(total - 1, slideDomIndex));
      if (slideDomIndex === total + 1) return 0;
      if (slideDomIndex === 0) return total - 1;
      return slideDomIndex - 1;
    };

    const announce = () => {
      const logical = logicalStable();
      if (status) status.textContent = `Grupo ${logical + 1} de ${total}`;
      dotButtons.forEach((btn, i) => {
        btn.setAttribute("aria-current", i === logical ? "true" : "false");
      });
    };

    const setTranslate = (domIdx, instant) => {
      const noAnim = instant || reduceMotionMq.matches;
      track.style.transition = noAnim ? "none" : "";
      track.style.transform = `translateX(${-domIdx * 100}%)`;
      slideDomIndex = domIdx;

      const flushHeight = () => {
        requestAnimationFrame(syncCarouselViewportHeight);
      };

      flushHeight();

      if (instant && reduceMotionMq.matches) return;

      if (instant && !reduceMotionMq.matches) {
        void track.offsetHeight;
        requestAnimationFrame(() => {
          track.style.transition = "";
          syncCarouselViewportHeight();
        });
      }
    };

    const onNavigateDone = () => {
      if (useSmoothLoop) {
        if (slideDomIndex === total + 1) setTranslate(1, true);
        else if (slideDomIndex === 0) setTranslate(total, true);
      }
      locked = false;
      announce();
    };

    const goAnimated = (targetDomIdx) => {
      if (locked || targetDomIdx === slideDomIndex) return;
      locked = true;
      setTranslate(targetDomIdx, reduceMotionMq.matches);
      announce();

      if (reduceMotionMq.matches) {
        onNavigateDone();
        return;
      }

      let done = false;
      const handleEnd = (e) => {
        if (done || e.target !== track || e.propertyName !== "transform") return;
        done = true;
        track.removeEventListener("transitionend", handleEnd);
        onNavigateDone();
      };
      track.addEventListener("transitionend", handleEnd);
      window.setTimeout(() => {
        if (done || !locked) return;
        done = true;
        track.removeEventListener("transitionend", handleEnd);
        onNavigateDone();
      }, 340);
    };

    const normalizeIfOnClone = () => {
      if (!useSmoothLoop) return;
      if (slideDomIndex === total + 1) setTranslate(1, true);
      else if (slideDomIndex === 0) setTranslate(total, true);
    };

    for (let i = 0; i < total; i += 1) {
      const b = document.createElement("button");
      b.type = "button";
      b.className = "menu-carta-carousel__dot";
      b.setAttribute("aria-label", `Ir al grupo ${i + 1} de ${total}`);
      const targetLogical = i;
      b.addEventListener("click", () => {
        if (locked) return;

        if (!useSmoothLoop) {
          slideDomIndex = targetLogical;
          setTranslate(slideDomIndex, reduceMotionMq.matches);
          announce();
          return;
        }

        normalizeIfOnClone();

        const targetDom = targetLogical + 1;

        if (slideDomIndex === targetDom) return;

        if (slideDomIndex === total && targetLogical === 0) {
          goAnimated(total + 1);
          return;
        }
        if (slideDomIndex === 1 && targetLogical === total - 1) {
          goAnimated(0);
          return;
        }

        goAnimated(targetDom);
      });

      dotsContainer.appendChild(b);
      dotButtons.push(b);
    }

    const step = (direction) => {
      if (locked || total <= 1) return;

      if (!useSmoothLoop) {
        const wrapsBackward = direction < 0 && slideDomIndex === 0;
        const wrapsForward = direction > 0 && slideDomIndex === total - 1;
        slideDomIndex = (slideDomIndex + direction + total) % total;
        setTranslate(slideDomIndex, wrapsBackward || wrapsForward);
        announce();
        return;
      }

      normalizeIfOnClone();

      if (direction > 0)
        goAnimated(slideDomIndex === total ? total + 1 : slideDomIndex + 1);

      else
        goAnimated(slideDomIndex <= 1 ? 0 : slideDomIndex - 1);
    };

    prev.addEventListener("click", () => step(-1));
    next.addEventListener("click", () => step(1));

    reduceMotionMq.addEventListener("change", () => {
      track.style.transition = reduceMotionMq.matches ? "none" : "";
      locked = false;
    });

    root.addEventListener("keydown", (e) => {
      if (!root.contains(document.activeElement)) return;
      if (e.key === "ArrowRight") {
        e.preventDefault();
        normalizeIfOnClone();
        step(1);
      } else if (e.key === "ArrowLeft") {
        e.preventDefault();
        normalizeIfOnClone();
        step(-1);
      }
    });

    locked = false;
    slideDomIndex = useSmoothLoop ? 1 : 0;
    setTranslate(useSmoothLoop ? 1 : 0, true);
    announce();
    syncCarouselViewportHeight();
  });

  const hero = document.getElementById("inicio");
  const orbs = hero ? hero.querySelectorAll(".hero-burst-orb") : [];
  const reducedMotion = reduceMotionMq.matches;
  if (hero && orbs.length && !reducedMotion) {
    window.addEventListener('mousemove', (event) => {
      const x = event.clientX / window.innerWidth - 0.5;
      const y = event.clientY / window.innerHeight - 0.5;
      orbs.forEach((orb, index) => {
        const factor = index === 0 ? 18 : -20;
        (orb as HTMLElement).style.transform = `translate3d(${x * factor}px, ${y * factor}px, 0)`;
      });
    });
  }
</script>
