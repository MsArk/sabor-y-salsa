---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Nav from "@/shared/components/Nav.astro";
import Footer from "@/shared/components/Footer.astro";
import LocationMapEmbed from "@/shared/components/LocationMapEmbed.astro";
import SocialLinksRound from "@/shared/components/SocialLinksRound.astro";
---

<BaseLayout title="Contacto | Sabor &amp; Salsa">
  <Nav activeLink="Contacto" />
  <main>
    <!-- Hero -->
    <section class="relative min-h-[50vh] flex items-center justify-center overflow-hidden pt-40 md:pt-40" id="contacto-hero">
      <div class="absolute inset-0 z-0">
        <div class="absolute inset-0 bg-gradient-to-b from-surface/40 via-surface/60 to-surface"></div>
        <div class="hero-burst-orb o1" aria-hidden="true"></div>
        <div class="hero-burst-orb o2" aria-hidden="true"></div>
      </div>
      <div class="relative z-10 text-center max-w-4xl px-6 reveal in">
        <span class="font-label text-primary uppercase tracking-[0.4em] text-xs mb-6 block">Hablemos</span>
        <h1 class="hero-title font-headline text-5xl md:text-7xl lg:text-8xl font-bold text-on-surface leading-none tracking-tighter mb-8">
          CONTACTO
        </h1>
        <p class="font-body text-lg md:text-xl text-on-surface-variant max-w-2xl mx-auto leading-relaxed">
          Estamos aqui para atenderte. Reservas, eventos privados o simplemente para saludar.
        </p>
      </div>
    </section>

    <!-- Contact Info & Form -->
    <section class="py-20 md:py-28 bg-surface-container-low reveal" style="--reveal-delay: 70ms">
      <div class="max-w-7xl mx-auto px-5 md:px-8 grid grid-cols-1 lg:grid-cols-12 gap-10 lg:gap-16">
        <!-- Info -->
        <div class="lg:col-span-5 space-y-8">
          <div>
            <span class="font-label text-primary uppercase tracking-[0.3em] text-[10px] font-bold">Encuentranos</span>
            <h2 class="font-headline text-3xl md:text-4xl font-bold mt-4 mb-8 leading-tight">Donde el <span class="italic text-primary font-normal">sabor</span> te espera</h2>
          </div>
          <div class="bg-surface p-6 md:p-8 rounded-xl border border-outline-variant/20 glow-card">
            <div class="flex items-start gap-4">
              <span class="material-symbols-outlined text-primary text-2xl mt-1">location_on</span>
              <div>
                <h3 class="font-headline text-xl font-bold mb-2">Madrid, España</h3>
                <p class="text-on-surface-variant mb-3">Calle Guadaira 14, Local nº 3 Madrid, España</p>
                <p class="font-label text-[10px] uppercase tracking-[0.18em] text-primary">Sede Original</p>
              </div>
            </div>
          </div>
          <div class="bg-surface p-6 md:p-8 rounded-xl border border-outline-variant/20 glow-card">
            <div class="flex items-start gap-4">
              <span class="material-symbols-outlined text-primary text-2xl mt-1">schedule</span>
              <div>
                <h3 class="font-headline text-xl font-bold mb-2">Horario</h3>
                <p class="text-on-surface-variant mb-1">Jueves - Domingo</p>
                <p class="text-primary font-semibold text-lg">6:00 PM - 2:00 AM</p>
              </div>
            </div>
          </div>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div class="bg-surface p-6 rounded-xl border border-outline-variant/20 glow-card min-w-0">
              <div class="flex items-start gap-3 min-w-0">
                <span class="material-symbols-outlined text-primary text-xl shrink-0">call</span>
                <div class="min-w-0">
                  <h4 class="font-label text-[10px] uppercase tracking-[0.18em] text-on-surface/70 mb-1">Telefono</h4>
                  <a href="tel:+34639810204" class="text-on-surface hover:text-primary transition-colors font-semibold">+34 639 81 02 04</a>
                </div>
              </div>
            </div>
            <div class="bg-surface p-6 rounded-xl border border-outline-variant/20 glow-card min-w-0">
              <div class="flex items-start gap-3 min-w-0">
                <span class="material-symbols-outlined text-primary text-xl shrink-0">mail</span>
                <div class="min-w-0">
                  <h4 class="font-label text-[10px] uppercase tracking-[0.18em] text-on-surface/70 mb-1">Email</h4>
                  <a href="mailto:barsaborysalsa@gmail.com" class="block max-w-full text-on-surface hover:text-primary transition-colors font-semibold text-sm break-words">barsaborysalsa@gmail.com</a>
                </div>
              </div>
            </div>
          </div>
          <SocialLinksRound class="pt-4" />
        </div>

        <!-- Form -->
        <div class="lg:col-span-7">
          <div class="bg-surface-container-high p-8 md:p-12 rounded-xl glow-card">
            <span class="font-label text-primary uppercase tracking-[0.28em] text-[11px] mb-4 block">Escribenos</span>
            <h2 class="font-headline text-3xl md:text-4xl font-bold leading-tight mb-8">Enviar <span class="italic text-primary font-normal">mensaje</span></h2>
            <form class="space-y-6" id="contact-form">
              <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
                <label class="block">
                  <span class="font-label text-[10px] uppercase tracking-[0.18em] text-on-surface/70">Nombre *</span>
                  <input class="mt-2 w-full bg-transparent border-0 border-b border-outline/40 focus:border-primary focus:ring-0 px-1 py-3 text-on-surface placeholder:text-on-surface/35"
                    placeholder="Tu nombre completo" type="text" name="nombre" required />
                </label>
                <label class="block">
                  <span class="font-label text-[10px] uppercase tracking-[0.18em] text-on-surface/70">Email *</span>
                  <input class="mt-2 w-full bg-transparent border-0 border-b border-outline/40 focus:border-primary focus:ring-0 px-1 py-3 text-on-surface placeholder:text-on-surface/35"
                    placeholder="tu@email.com" type="email" name="email" required />
                </label>
              </div>
              <label class="block">
                <span class="font-label text-[10px] uppercase tracking-[0.18em] text-on-surface/70">Asunto *</span>
                <select class="mt-2 w-full bg-transparent border-0 border-b border-outline/40 focus:border-primary focus:ring-0 px-1 py-3 text-on-surface" name="asunto" required>
                  <option value="" class="bg-surface-container-high">Selecciona un asunto</option>
                  <option value="reserva" class="bg-surface-container-high">Reserva de mesa</option>
                  <option value="evento" class="bg-surface-container-high">Evento privado</option>
                  <option value="catering" class="bg-surface-container-high">Catering</option>
                  <option value="prensa" class="bg-surface-container-high">Prensa y medios</option>
                  <option value="colaboracion" class="bg-surface-container-high">Colaboracion</option>
                  <option value="otro" class="bg-surface-container-high">Otro</option>
                </select>
              </label>
              <label class="block">
                <span class="font-label text-[10px] uppercase tracking-[0.18em] text-on-surface/70">Mensaje *</span>
                <textarea class="mt-2 w-full bg-transparent border-0 border-b border-outline/40 focus:border-primary focus:ring-0 px-1 py-3 text-on-surface placeholder:text-on-surface/35 resize-none"
                  placeholder="Cuentanos como podemos ayudarte..." name="mensaje" rows="5" required></textarea>
              </label>
              <div class="pt-4">
                <button type="submit" class="metallic-gradient text-on-primary font-label font-bold px-10 py-4 rounded-lg uppercase tracking-widest btn-hover-strong w-full sm:w-auto">
                  Enviar Mensaje
                </button>
              </div>
            </form>
          </div>
        </div>
      </div>
    </section>

    <!-- Mapa (Google Maps) -->
    <section class="py-16 md:py-24 bg-surface reveal" style="--reveal-delay: 120ms">
      <div class="max-w-7xl mx-auto px-5 md:px-8">
        <div class="text-center mb-12">
          <span class="font-label text-primary uppercase tracking-[0.3em] text-[10px] font-bold">Visitanos</span>
          <h2 class="font-headline text-3xl md:text-4xl font-bold mt-4">Nuestra <span class="italic text-primary font-normal">ubicacion</span></h2>
        </div>
        <LocationMapEmbed />
      </div>
    </section>

    <!-- CTA -->
    <section class="py-20 md:py-28 bg-surface-container-high reveal" style="--reveal-delay: 150ms">
      <div class="max-w-4xl mx-auto px-5 md:px-8 text-center">
        <span class="material-symbols-outlined text-primary text-5xl mb-6">restaurant</span>
        <h2 class="font-headline text-4xl md:text-5xl font-bold mb-6">Listo para <span class="italic text-primary font-normal">el fuego?</span></h2>
        <p class="text-on-surface-variant text-lg mb-10 max-w-2xl mx-auto">Reserva tu mesa y vive la experiencia Sabor &amp; Salsa. Donde cada plato cuenta una historia del Callao.</p>
        <a class="metallic-gradient text-on-primary font-label font-bold px-10 py-4 rounded-lg uppercase tracking-widest btn-hover-strong inline-block" href="/#reservas">Reservar Mesa</a>
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>

<script>
  const revealNodes = document.querySelectorAll('.reveal');
  const observer = new IntersectionObserver((entries) => {
    entries.forEach((entry) => {
      if (entry.isIntersecting) { entry.target.classList.add('in'); observer.unobserve(entry.target); }
    });
  }, { threshold: 0.2 });
  revealNodes.forEach((node) => observer.observe(node));
</script>
